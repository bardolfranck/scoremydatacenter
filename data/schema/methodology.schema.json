{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scoremydatacenter.org/schema/methodology.schema.json",
  "title": "Scoring methodology",
  "description": "The versioned scoring grid. Every threshold must carry its basis (external reference or justified editorial choice) — threshold traceability is a schema constraint, not a good practice. Cross-field invariants (pillar weights sum to 1, per-pillar indicator weights sum to 1) are engine gates.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "status", "published_at", "pillars", "indicators", "confidence", "grade_thresholds", "parameters"],
  "properties": {
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-draft)?$" },
    "status": { "enum": ["draft", "published"] },
    "published_at": { "type": ["string", "null"], "format": "date" },
    "pillars": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "weight"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z_]*$" },
          "label": { "$ref": "#/$defs/bilingual_label" },
          "weight": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
        }
      }
    },
    "indicators": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/indicator_definition" }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tier_weights", "causes"],
      "properties": {
        "tier_weights": {
          "type": "object",
          "additionalProperties": false,
          "required": ["1", "2", "3"],
          "properties": {
            "1": { "type": "number", "minimum": 0, "maximum": 1 },
            "2": { "type": "number", "minimum": 0, "maximum": 1 },
            "3": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "causes": {
          "const": ["unverifiable_declarative", "missing_data"],
          "description": "Always reported separately — a declarative claim is not the same failure as an absent datum."
        }
      }
    },
    "grade_thresholds": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["min", "grade"],
        "properties": {
          "min": { "type": "number", "minimum": 0, "maximum": 100 },
          "grade": { "enum": ["A", "B", "C", "D", "E"] }
        }
      }
    },
    "parameters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["declarative_score_cap", "min_coverage_project_process", "provisional"],
      "properties": {
        "declarative_score_cap": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Prudent-scoring rule: an 'announced' (unverified) value cannot push its normalized contribution above this cap."
        },
        "min_coverage_project_process": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Below this weighted coverage, the project/process grade is 'insufficient_data' instead of a letter."
        },
        "provisional": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "bilingual_label": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fr", "en"],
      "properties": {
        "fr": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      }
    },
    "indicator_definition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "pillar", "weight_in_pillar", "block", "tier", "nature", "unit", "direction", "mvp", "calibration_status", "sources", "normalization", "threshold_basis"],
      "allOf": [
        {
          "if": { "properties": { "direction": { "const": "non_monotonic" } } },
          "then": {
            "required": ["calibration_note"],
            "properties": { "calibration_status": { "const": "provisional" } },
            "$comment": "An ambiguous indicator is not a question — it is non_monotonic + a note, and it cannot claim to be calibrated."
          }
        },
        {
          "if": { "required": ["constraints"] },
          "then": { "required": ["calibration_note"] }
        }
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[EWFLT][0-9]{1,2}$" },
        "label": { "$ref": "#/$defs/bilingual_label" },
        "pillar": { "type": "string", "pattern": "^[a-z][a-z_]*$" },
        "weight_in_pillar": { "type": "number", "minimum": 0, "maximum": 1 },
        "block": {
          "enum": ["base", "project", "process"],
          "description": "base = endured by the project (site score); project/process = operator choices (project/process score, the levers)."
        },
        "tier": {
          "enum": [1, 2, 3],
          "description": "Data availability tier: 1 = public APIs/layers, 2 = extractable documents (press, permitting, deliberations), 3 = operator-only."
        },
        "nature": {
          "enum": ["public_fact", "declarative", "factualized_judgment"],
          "description": "Decides the treatment: fact -> scored directly; declarative -> tagged 'announced', prudent score, ex-post re-score; judgment -> never a verdict, only closed procedural proxies."
        },
        "unit": { "type": ["string", "null"] },
        "direction": {
          "enum": ["lower_is_better", "higher_is_better", "encoded_in_scoring", "non_monotonic"],
          "description": "Mandatory declared scoring sense — the blind-spot killer. lower/higher_is_better = monotone numeric; encoded_in_scoring = ordering fully and unambiguously carried by category/rubric scores; non_monotonic = the sense itself is unsettled (requires calibration_note, resolved in phase-5 calibration or by an explicit constraint, never by asking)."
        },
        "mvp": { "type": "boolean" },
        "calibration_status": { "enum": ["provisional", "calibrated"] },
        "calibration_note": {
          "type": "string",
          "minLength": 1,
          "description": "Plain-language framing of what remains to settle and how (calibration vs definition vs ethical constraint)."
        },
        "constraints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["vulnerability_cannot_improve_score"],
            "$comment": "Closed list on purpose: an unknown constraint must fail validation, not silently no-op. Adding one = schema change = conscious act. vulnerability_cannot_improve_score = ethical lock (framing note section 9): retrospective calibration must never learn 'fragile municipality = better grade'."
          }
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "normalization": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "thresholds"],
              "properties": {
                "type": { "const": "thresholds" },
                "thresholds": {
                  "type": "array",
                  "minItems": 2,
                  "items": {
                    "oneOf": [
                      {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["up_to", "score"],
                        "properties": {
                          "up_to": { "type": "number" },
                          "score": { "type": "number", "minimum": 0, "maximum": 100 }
                        }
                      },
                      {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["above", "score"],
                        "properties": {
                          "above": { "const": true },
                          "score": { "type": "number", "minimum": 0, "maximum": 100 }
                        }
                      }
                    ]
                  }
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "min", "max"],
              "properties": {
                "type": { "const": "bounded_linear" },
                "min": { "type": "number" },
                "max": { "type": "number" }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "categories"],
              "properties": {
                "type": { "const": "categorical" },
                "categories": {
                  "type": "object",
                  "minProperties": 2,
                  "additionalProperties": { "type": "number", "minimum": 0, "maximum": 100 }
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "rubric"],
              "properties": {
                "type": { "const": "proxy_rubric" },
                "rubric": {
                  "type": "object",
                  "description": "Points per procedural proxy (T1). Structure finalized with the engine; draft values are PROVISIONAL.",
                  "minProperties": 1
                }
              }
            }
          ]
        },
        "threshold_basis": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "enum": ["reference", "editorial_choice"] },
            "reference": { "type": "string", "minLength": 1 },
            "url": { "type": "string", "format": "uri" },
            "rationale": { "type": "string", "minLength": 1 }
          },
          "allOf": [
            {
              "if": { "properties": { "type": { "const": "reference" } } },
              "then": { "required": ["reference"] }
            },
            {
              "if": { "properties": { "type": { "const": "editorial_choice" } } },
              "then": { "required": ["rationale"] }
            }
          ]
        }
      }
    }
  }
}
