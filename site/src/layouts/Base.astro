---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Copyright (C) 2026 Franck Bardol and contributors — ScoreMyDataCenter
// https://scoremydatacenter.org · independent data center acceptability-risk score
import "../styles/global.css";

interface Props {
  lang: "en" | "fr";
  title: string;
  description: string;
  tagline: string;
  altHref: string; // path of the same page in the other language
  altLabel: string;
  nav: { href: string; label: string }[];
  ogImage?: string; // absolute URL of the social card
}
const { lang, title, description, tagline, altHref, altLabel, nav, ogImage } = Astro.props;
const altLang = lang === "en" ? "fr" : "en";
const home = lang === "en" ? "/" : "/fr/";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta name="twitter:card" content="summary_large_image" />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="icon" type="image/svg+xml" href="/assets/smdc-icon.svg" />
    <link rel="alternate" hreflang={altLang} href={altHref} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={home} aria-label="ScoreMyDataCenter home">
        <img src="/assets/smdc-icon.svg" alt="" width="40" height="40" />
        <span class="brand-text">
          <span class="brand-name">Score<span class="brand-my">My</span>DataCenter</span>
          <span class="brand-bars" aria-hidden="true"><i class="b-a"></i><i class="b-b"></i><i class="b-c"></i><i class="b-d"></i><i class="b-e"></i></span>
          <span class="brand-tagline">{tagline}</span>
        </span>
      </a>
      <form class="header-search" action={lang === "fr" ? "/fr/classement" : "/ranking"} method="get" role="search">
        <input type="search" name="q"
          placeholder={lang === "fr" ? "Rechercher un site, un opérateur, un pays…" : "Search a site, an operator, a country…"}
          aria-label={lang === "fr" ? "Rechercher dans les projets notés" : "Search the scored projects"} />
      </form>
      <nav class="main-nav" aria-label="Site sections">
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
        <a class="lang-switch" href={altHref}>{altLabel}</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer footer-v2">
      <div class="footer-brand">
        <span class="footer-name">Score<span class="brand-my">My</span>DataCenter</span>
        <p>{lang === "fr"
          ? "Observatoire indépendant du risque d'acceptabilité des data centers."
          : "Independent observatory of data-center acceptability risk."}</p>
        <p class="footer-lic">Engine AGPL-3.0 · Data: licence by source (ODbL, Licence Ouverte…) · Methodology CC BY-SA 4.0<br/>© 2026 Franck Bardol and contributors</p>
      </div>
      {(lang === "fr" ? [
        ["Explorer", [["Carte", "/fr/carte"], ["Classement", "/fr/classement"], ["Indices pays", "/fr/indices"], ["Les chiffres du parc", "/fr/chiffres"], ["Comprendre les data centers", "/fr/comprendre"]]],
        ["Ressources", [["Méthodologie", "/fr/methodologie"], ["Modèle ouvert", "/fr/#open"], ["Bibliothèque", "/fr/bibliotheque"], ["FAQ", "/fr/#faq"]]],
        ["À propos", [["Qui sommes-nous ?", "/fr/qui-sommes-nous"], ["Contact", "/fr/contact"], ["Mentions légales", "/fr/mentions-legales"]]],
      ] : [
        ["Explore", [["Map", "/map"], ["Ranking", "/ranking"], ["Country index", "/indices"], ["Fleet figures", "/figures"], ["Understanding data centers", "/understand"]]],
        ["Resources", [["Methodology", "/methodology"], ["Open model", "/#open"], ["Library", "/intelligence"], ["FAQ", "/#faq"]]],
        ["About", [["Who we are", "/who-we-are"], ["Contact", "/contact"], ["Legal notices", "/legal"]]],
      ]).map(([heading, links]: any) => (
        <div class="footer-col">
          <h4>{heading}</h4>
          <ul>{links.map(([label, href]: any) => <li><a href={href}>{label}</a></li>)}</ul>
        </div>
      ))}
    </footer>
    <!-- Audience measurement (GA4) is consent-gated: nothing loads and no cookie
         is set until the visitor clicks Accept. Choice kept 6 months, revocable
         from the legal-notices page (CNIL guidelines). -->
    <div class="consent-banner" id="consent-banner" hidden role="dialog" aria-live="polite"
      aria-label={lang === "fr" ? "Consentement à la mesure d'audience" : "Audience-measurement consent"}>
      <p class="consent-text">
        {lang === "fr"
          ? "Mesure d'audience : nous utilisons Google Analytics pour compter les visites et comprendre ce qui est lu. Aucun cookie n'est déposé sans votre accord."
          : "Audience measurement: we use Google Analytics to count visits and understand what gets read. No cookie is set without your consent."}
        <a href={lang === "fr" ? "/fr/mentions-legales" : "/legal"}>
          {lang === "fr" ? "En savoir plus" : "Learn more"}</a>
      </p>
      <div class="consent-actions">
        <button class="button button-secondary" type="button" data-consent="denied">
          {lang === "fr" ? "Refuser" : "Decline"}</button>
        <button class="button button-secondary" type="button" data-consent="granted">
          {lang === "fr" ? "Accepter" : "Accept"}</button>
      </div>
    </div>
    <script is:inline>
      (function () {
        var KEY = "smdc-consent";
        var MAX_AGE = 182 * 24 * 3600 * 1000; // re-ask after ~6 months (CNIL)
        function readChoice() {
          try {
            var raw = localStorage.getItem(KEY);
            if (!raw) return null;
            var c = JSON.parse(raw);
            if (!c || !c.v || Date.now() - c.t > MAX_AGE) { localStorage.removeItem(KEY); return null; }
            return c.v;
          } catch (e) { return null; }
        }
        function loadGA() {
          window.dataLayer = window.dataLayer || [];
          window.gtag = function () { dataLayer.push(arguments); };
          gtag("js", new Date());
          gtag("config", "G-L6TGP1783C");
          var el = document.createElement("script");
          el.async = true;
          el.src = "https://www.googletagmanager.com/gtag/js?id=G-L6TGP1783C";
          document.head.appendChild(el);
        }
        window.smdcConsentReset = function () { localStorage.removeItem(KEY); location.reload(); };
        var banner = document.getElementById("consent-banner");
        var choice = readChoice();
        if (choice === "granted") loadGA();
        else if (choice === null && banner) {
          banner.hidden = false;
          banner.addEventListener("click", function (ev) {
            var v = ev.target && ev.target.getAttribute && ev.target.getAttribute("data-consent");
            if (!v) return;
            try { localStorage.setItem(KEY, JSON.stringify({ v: v, t: Date.now() })); } catch (e) {}
            banner.hidden = true;
            if (v === "granted") loadGA();
          });
        }
      })();
    </script>
  </body>
</html>
