---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Copyright (C) 2026 Franck Bardol and contributors — ScoreMyDataCenter
// https://scoremydatacenter.org · independent data center acceptability-risk score
import "../styles/global.css";

interface Props {
  lang: "en" | "fr";
  title: string;
  description: string;
  tagline: string;
  altHref: string; // path of the same page in the other language
  altLabel: string;
  nav: { href: string; label: string }[];
  ogImage?: string; // absolute URL of the social card
}
const { lang, title, description, tagline, altHref, altLabel, nav, ogImage } = Astro.props;
const altLang = lang === "en" ? "fr" : "en";
const home = lang === "en" ? "/" : "/fr/";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta name="twitter:card" content="summary_large_image" />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="icon" type="image/svg+xml" href="/assets/smdc-icon.svg" />
    <link rel="alternate" hreflang={altLang} href={altHref} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={home} aria-label="ScoreMyDataCenter home">
        <img src="/assets/smdc-icon.svg" alt="" width="40" height="40" />
        <span class="brand-text">
          <span class="brand-name">Score<span class="brand-my">My</span>DataCenter</span>
          <span class="brand-bars" aria-hidden="true"><i class="b-a"></i><i class="b-b"></i><i class="b-c"></i><i class="b-d"></i><i class="b-e"></i></span>
          <span class="brand-tagline">{tagline}</span>
        </span>
      </a>
      <form class="header-search" action={lang === "fr" ? "/fr/classement" : "/ranking"} method="get" role="search">
        <input type="search" name="q"
          placeholder={lang === "fr" ? "Rechercher un site, un opérateur, un pays…" : "Search a site, an operator, a country…"}
          aria-label={lang === "fr" ? "Rechercher dans les projets notés" : "Search the scored projects"} />
      </form>
      <nav class="main-nav" aria-label="Site sections">
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
        <a class="lang-switch" href={altHref}>{altLabel}</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer footer-v2">
      <div class="footer-brand">
        <span class="footer-name">Score<span class="brand-my">My</span>DataCenter</span>
        <p>{lang === "fr"
          ? "Observatoire indépendant du risque d'acceptabilité des data centers."
          : "Independent observatory of data-center acceptability risk."}</p>
        <p class="footer-lic">Engine AGPL-3.0 · Data: licence by source (ODbL, Licence Ouverte…) · Methodology CC BY-SA 4.0<br/>© 2026 Franck Bardol and contributors</p>
      </div>
      {(lang === "fr" ? [
        ["Explorer", [["Carte", "/fr/carte"], ["Classement", "/fr/classement"], ["Comprendre les data centers", "/fr/comprendre"]]],
        ["Ressources", [["Méthodologie", "/fr/methodologie"], ["Modèle ouvert", "/fr/#open"], ["Bibliothèque", "/fr/bibliotheque"], ["FAQ", "/fr/#faq"]]],
        ["À propos", [["Qui sommes-nous ?", "/fr/#about"], ["Contact", "/fr/contact"], ["Mentions légales", "/fr/mentions-legales"]]],
      ] : [
        ["Explore", [["Map", "/map"], ["Ranking", "/ranking"], ["Understanding data centers", "/understand"]]],
        ["Resources", [["Methodology", "/methodology"], ["Open model", "/#open"], ["Library", "/intelligence"], ["FAQ", "/#faq"]]],
        ["About", [["Who we are", "/#about"], ["Contact", "/contact"], ["Legal notices", "/legal"]]],
      ]).map(([heading, links]: any) => (
        <div class="footer-col">
          <h4>{heading}</h4>
          <ul>{links.map(([label, href]: any) => <li><a href={href}>{label}</a></li>)}</ul>
        </div>
      ))}
    </footer>
  </body>
</html>
