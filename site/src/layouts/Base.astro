---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Copyright (C) 2026 Franck Bardol and contributors — ScoreMyDataCenter
// https://scoremydatacenter.org · independent data center acceptability-risk score
import "../styles/global.css";

interface Props {
  lang: "en" | "fr";
  title: string;
  description: string;
  tagline: string;
  altHref: string; // path of the same page in the other language
  altLabel: string;
  nav: { href: string; label: string }[];
  ogImage?: string; // absolute URL of the social card
}
const { lang, title, description, tagline, altHref, altLabel, nav, ogImage } = Astro.props;
const altLang = lang === "en" ? "fr" : "en";
const home = lang === "en" ? "/" : "/fr/";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta name="twitter:card" content="summary_large_image" />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="icon" type="image/svg+xml" href="/assets/smdc-icon.svg" />
    <link rel="alternate" hreflang={altLang} href={altHref} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={home} aria-label="ScoreMyDataCenter home">
        <img src="/assets/smdc-icon.svg" alt="" width="40" height="40" />
        <span class="brand-text">
          <span class="brand-name">Score<span class="brand-my">My</span>DataCenter</span>
          <span class="brand-bars" aria-hidden="true"><i class="b-a"></i><i class="b-b"></i><i class="b-c"></i><i class="b-d"></i><i class="b-e"></i></span>
          <span class="brand-tagline">{tagline}</span>
        </span>
      </a>
      <nav class="main-nav" aria-label="Site sections">
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
        <a class="lang-switch" href={altHref}>{altLabel}</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>© 2026 Franck Bardol and contributors — Score<span class="brand-my">My</span>DataCenter</span>
      <span class="footer-links">{lang === "fr"
        ? <Fragment><a href="/fr/mentions-legales">Mentions légales</a> · <a href="/fr/contact">Contact</a></Fragment>
        : <Fragment><a href="/legal">Legal notices</a> · <a href="/contact">Contact</a></Fragment>}</span>
      <span>Engine AGPL-3.0 · Data: licence by source (ODbL, Licence Ouverte…) · Methodology CC BY-SA 4.0</span>
    </footer>
  </body>
</html>
