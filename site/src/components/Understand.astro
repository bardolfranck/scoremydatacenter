// "Understanding data centers" — the second acquisition layer (framing note
// §4): light, didactic, for the local official and the resident. Seven-block
// structure; editorial texts land block by block from the methodology lead
// (block 3, the five-pillar checklist one-pager, ships first).
import Base from "../layouts/Base.astro";
import type { Checklist } from "../content/questions";
import type { WhatIsDC } from "../content/what-is-a-dc";
import type { RichBlock } from "../content/understand-blocks";
import PillarIcon from "./PillarIcon.astro";
import PowerScale from "./PowerScale.astro";

interface Props {
  lang: "en" | "fr";
  t: Record<string, any>;
  checklist?: Checklist;
  whatIs?: WhatIsDC;
  rich?: Record<string, RichBlock>;
}
const { lang, t, checklist, whatIs, rich = {} } = Astro.props;
---

<Base
  lang={lang}
  title={t.title}
  description={t.description}
  tagline={t.tagline}
  altHref={t.altHref}
  altLabel={t.altLabel}
  nav={t.nav}
>
  <section class="section" aria-labelledby="learn-title">
    <div class="section-inner">
      <div class="section-heading">
        <h2 id="learn-title">{t.pageTitle}</h2>
        <p>{t.lede}</p>
      </div>
      {t.contextNotice && <p class="context-notice" set:html={t.contextNotice}></p>}
      <nav class="learn-toc" aria-label={t.tocAria}>
        {t.blocks.map((block: any, i: number) => (
          <a href={`#${block.anchor}`}>{i + 1} · {block.title}</a>
        ))}
      </nav>

      <div class="learn-grid">
        {t.blocks.map((block: any, i: number) => (
          <article class={`learn-block ${block.featured ? "featured" : ""} ${block.slot ? "filled foldable folded" : ""}`} id={block.anchor}>
            <span class="learn-number" aria-hidden="true">{i + 1}</span>
            <h3>{block.title} {block.tag && <span class="france-tag">{block.tag}</span>}</h3>
            {block.body && <p>{block.body}</p>}
            {block.pending && <span class="fixture-tag">{t.pendingLabel}</span>}
            <div class="block-content">
            {block.slot === "rich" && rich[block.anchor] && (
              <div class="richblock">
                {rich[block.anchor].intro && <p class="whatis-p" set:html={rich[block.anchor].intro}></p>}
                {rich[block.anchor].points && (
                  <div class="rich-points">
                    {rich[block.anchor].points.map((point: any) => (
                      <p class="whatis-p rich-point">
                        {point.icon && <PillarIcon name={point.icon} size={17} />}
                        <span><strong>{point.lead}</strong> <span set:html={point.body}></span></span>
                      </p>
                    ))}
                  </div>
                )}
                {rich[block.anchor].qas && (
                  <div class="rich-qas">
                    {rich[block.anchor].qas.map((qa: any) => (
                      <div class="rich-qa">
                        <p class="checklist-q">« {qa.q} »</p>
                        <p class="checklist-why" set:html={qa.a}></p>
                      </div>
                    ))}
                  </div>
                )}
                {rich[block.anchor].linkGroups && (
                  <div class="rich-linkgroups">
                    {rich[block.anchor].linkGroups.map((group: any) => (
                      <section class="checklist-group">
                        <h4>{group.title}</h4>
                        <ul class="rich-links">
                          {group.links.map((link: any) => (
                            <li>
                              {link.url
                                ? <a href={link.url} target="_blank" rel="noopener"><strong>{link.name}</strong></a>
                                : <strong>{link.name}</strong>}
                              {" — "}{link.desc}
                            </li>
                          ))}
                        </ul>
                      </section>
                    ))}
                  </div>
                )}
                {rich[block.anchor].inFrance && (
                  <p class="in-france"><strong>{t.inFranceLabel}</strong> <span set:html={rich[block.anchor].inFrance}></span></p>
                )}
                {rich[block.anchor].closing && <p class="whatis-p" set:html={rich[block.anchor].closing}></p>}
                {rich[block.anchor].takeaway && (
                  <p class="checklist-takeaway"><strong>{t.takeawayLabel}</strong> <span set:html={rich[block.anchor].takeaway}></span></p>
                )}
                {rich[block.anchor].sources && (
                  <p class="block-sources">
                    {t.sourcesLabel}
                    {rich[block.anchor].sources.map((src: any, n: number) => (
                      <span class="src-item" id={`src-${block.anchor}-${n + 1}`}> {n + 1}. <a href={src.url} target="_blank" rel="noopener">{src.label}</a>{n < rich[block.anchor].sources.length - 1 ? " ·" : ""}</span>
                    ))}
                  </p>
                )}
              </div>
            )}
            {block.slot === "whatis" && whatIs && (
              <div class="whatis">
                {whatIs.paragraphs.map((para) => <p class="whatis-p" set:html={para}></p>)}
                <p class="whatis-sizes-title"><strong>{whatIs.sizesTitle}</strong></p>
                <div class="learn-table-wrap">
                  <table class="learn-table">
                    <tbody>
                      {whatIs.sizes.map((row) => (
                        <tr>
                          <th scope="row">{row.label}</th>
                          <td class="learn-table-power">{row.power}</td>
                          <td>{row.note}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
                <PowerScale items={whatIs.scale.items} caption={whatIs.scale.caption} />
                <p class="whatis-p">{whatIs.statsParagraph}</p>
                <p class="checklist-takeaway"><strong>{t.takeawayLabel}</strong> {whatIs.takeaway}</p>
                <p class="block-sources">
                  {whatIs.sourcesLabel}
                  {whatIs.sources.map((src, n) => (
                    <span class="src-item" id={`src-${block.anchor}-${n + 1}`}> {n + 1}. <a href={src.url} target="_blank" rel="noopener">{src.label}</a>{n < whatIs.sources.length - 1 ? " ·" : ""}</span>
                  ))}
                </p>
              </div>
            )}
            {block.slot === "checklist" && checklist && (
              <div class="checklist">
                <p class="checklist-intro">{checklist.intro}</p>
                <div class="checklist-groups">
                  {checklist.groups.map((group) => (
                    <section class="checklist-group">
                      <h4><PillarIcon name={group.icon} /> {group.pillar}</h4>
                      {group.items.map((item) => (
                        <div class="checklist-item">
                          <p class="checklist-q">« {item.q} »</p>
                          <p class="checklist-why" set:html={`${t.whyLabel} ${item.why}`}></p>
                        </div>
                      ))}
                    </section>
                  ))}
                </div>
                <p class="checklist-takeaway"><strong>{t.takeawayLabel}</strong> {checklist.takeaway}</p>
                <div class="checklist-actions">
                  <a class="button button-primary" href={checklist.pdfHref} download>{checklist.pdfLabel}</a>
                  <a class="button button-secondary" href={checklist.printHref}>{checklist.printLabel}</a>
                </div>
              </div>
            )}
            </div>
            {block.slot && (
              <button class="fold-toggle" type="button" data-more={t.seeMore} data-less={t.seeLess}>{t.seeMore}</button>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>

<script>
  // Fold/expand: filled blocks start folded (a few visible lines + fade).
  // Arriving via an anchor (internal links, TOC, footnote refs) auto-expands
  // the target block so no reference ever lands on hidden text.
  function setLabel(btn: HTMLElement, folded: boolean) {
    btn.textContent = folded ? btn.dataset.more || "" : btn.dataset.less || "";
  }
  document.querySelectorAll<HTMLElement>(".fold-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const block = btn.closest(".learn-block");
      if (!block) return;
      const folded = block.classList.toggle("folded");
      setLabel(btn, folded);
      if (folded) block.scrollIntoView({ block: "start" });
    });
  });
  function expandTarget() {
    const id = decodeURIComponent(location.hash.slice(1));
    if (!id) return;
    const el = document.getElementById(id);
    const block = el?.closest ? (el.closest(".learn-block") as HTMLElement | null) : null;
    if (block?.classList.contains("folded")) {
      block.classList.remove("folded");
      const btn = block.querySelector<HTMLElement>(".fold-toggle");
      if (btn) setLabel(btn, false);
    }
  }
  window.addEventListener("hashchange", expandTarget);
  expandTarget();
</script>
