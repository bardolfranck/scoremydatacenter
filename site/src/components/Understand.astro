// https://scoremydatacenter.org · independent data center acceptability-risk score
// "Understanding data centers" — the second acquisition layer (framing note
// §4): light, didactic, for the local official and the resident. Seven-block
// structure; editorial texts land block by block from the methodology lead
// (block 3, the five-pillar checklist one-pager, ships first).
import Base from "../layouts/Base.astro";
import type { Checklist } from "../content/questions";
import type { WhatIsDC } from "../content/what-is-a-dc";
import PillarIcon from "./PillarIcon.astro";
import PowerScale from "./PowerScale.astro";

interface Props {
  lang: "en" | "fr";
  t: Record<string, any>;
  checklist?: Checklist;
  whatIs?: WhatIsDC;
}
const { lang, t, checklist, whatIs } = Astro.props;
---

<Base
  lang={lang}
  title={t.title}
  description={t.description}
  tagline={t.tagline}
  altHref={t.altHref}
  altLabel={t.altLabel}
  nav={t.nav}
>
  <section class="section" aria-labelledby="learn-title">
    <div class="section-inner">
      <div class="section-heading">
        <h2 id="learn-title">{t.pageTitle}</h2>
        <p>{t.lede}</p>
      </div>

      <div class="learn-grid">
        {t.blocks.map((block: any, i: number) => (
          <article class={`learn-block ${block.featured ? "featured" : ""} ${block.slot ? "filled" : ""}`} id={block.anchor}>
            <span class="learn-number" aria-hidden="true">{i + 1}</span>
            <h3>{block.title}</h3>
            {block.body && <p>{block.body}</p>}
            {block.pending && <span class="fixture-tag">{t.pendingLabel}</span>}
            {block.slot === "whatis" && whatIs && (
              <div class="whatis">
                {whatIs.paragraphs.map((para) => <p class="whatis-p" set:html={para}></p>)}
                <p class="whatis-sizes-title"><strong>{whatIs.sizesTitle}</strong></p>
                <div class="learn-table-wrap">
                  <table class="learn-table">
                    <tbody>
                      {whatIs.sizes.map((row) => (
                        <tr>
                          <th scope="row">{row.label}</th>
                          <td class="learn-table-power">{row.power}</td>
                          <td>{row.note}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
                <PowerScale items={whatIs.scale.items} caption={whatIs.scale.caption} />
                <p class="whatis-p">{whatIs.statsParagraph}</p>
                <p class="checklist-takeaway"><strong>{t.takeawayLabel}</strong> {whatIs.takeaway}</p>
                <p class="block-sources">
                  {whatIs.sourcesLabel}
                  {whatIs.sources.map((src, n) => (
                    <> <a href={src.url} target="_blank" rel="noopener">{src.label}</a>{n < whatIs.sources.length - 1 ? " · " : ""}</>
                  ))}
                </p>
              </div>
            )}
            {block.featured && checklist && (
              <div class="checklist">
                <p class="checklist-intro">{checklist.intro}</p>
                <div class="checklist-groups">
                  {checklist.groups.map((group) => (
                    <section class="checklist-group">
                      <h4><PillarIcon name={group.icon} /> {group.pillar}</h4>
                      {group.items.map((item) => (
                        <div class="checklist-item">
                          <p class="checklist-q">« {item.q} »</p>
                          <p class="checklist-why" set:html={`${t.whyLabel} ${item.why}`}></p>
                        </div>
                      ))}
                    </section>
                  ))}
                </div>
                <p class="checklist-takeaway"><strong>{t.takeawayLabel}</strong> {checklist.takeaway}</p>
                <a class="button button-secondary checklist-print" href={checklist.printHref}>{checklist.printLabel}</a>
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>
