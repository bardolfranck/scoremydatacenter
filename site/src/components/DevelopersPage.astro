---

<section class="dev-hero">
  <div class="section-inner">
    <p class="hero-eyebrow">{t.eyebrow}</p>
    <h1>{t.title}</h1>
    <p class="dev-usage" set:html={t.usage}></p>
    <div class="dev-meta">
      {t.badges.map((b: string) => <span class="dev-badge">{b}</span>)}
      <span class="dev-indexed">{t.indexed}</span>
    </div>
    <p class="dev-lede" set:html={t.lede}></p>
    <div class="dev-base dev-copyable">
      <span class="dev-base-label">{t.baseLabel}</span>
      <code class="dev-copy-src">{API_BASE}</code>
      <button class="dev-copy-btn" type="button" data-copy={t.copy} data-copied={t.copied} aria-label={t.copy}>{t.copy}</button>
    </div>
  </div>
</section>

<section class="section">
  <div class="section-inner">
    <h2 class="dev-h2">{t.qsTitle}</h2>
    <p class="dev-body">{t.qsNote}</p>
    <div class="dev-qs">
      <div class="dev-codewrap dev-copyable">
        <p class="dev-code-label">curl</p>
        <pre class="dev-code"><code class="dev-copy-src">{listCurl}</code></pre>
        <button class="dev-copy-btn dev-copy-abs" type="button" data-copy={t.copy} data-copied={t.copied} aria-label={t.copy}>{t.copy}</button>
      </div>
      <div class="dev-codewrap dev-copyable">
        <p class="dev-code-label">Python</p>
        <pre class="dev-code"><code class="dev-copy-src">{listPy}</code></pre>
        <button class="dev-copy-btn dev-copy-abs" type="button" data-copy={t.copy} data-copied={t.copied} aria-label={t.copy}>{t.copy}</button>
      </div>
    </div>
  </div>
</section>

<section class="section section-tinted">
  <div class="section-inner">
    <h2 class="dev-h2">{t.epTitle}</h2>

    <article class="dev-ep">
      <header class="dev-ep-head">
        <span class="dev-verb">GET</span>
        <code class="dev-route">/v1/datacenters</code>
        <span class="dev-tag dev-tag-free">{t.listTag}</span>
      </header>
      <p class="dev-ep-name">{t.listName}</p>
      <p class="dev-ep-desc" set:html={t.listDesc}></p>
      <p class="dev-code-label">{t.reqLabel}</p>
      <div class="dev-codewrap dev-copyable">
        <pre class="dev-code"><code class="dev-copy-src">{listCurl}</code></pre>
        <button class="dev-copy-btn dev-copy-abs" type="button" data-copy={t.copy} data-copied={t.copied} aria-label={t.copy}>{t.copy}</button>
      </div>
      <p class="dev-code-label">{t.respLabel}</p>
      <div class="dev-resp dev-copyable">
        <div class="dev-resp-bar"><span class="dev-resp-status">{t.jsonHeader}</span><button class="dev-copy-btn" type="button" data-copy={t.copy} data-copied={t.copied} aria-label={t.copy}>{t.copy}</button></div>
        <pre class="dev-code dev-code-resp"><code class="dev-copy-src" set:html={highlightJson(listJson)}></code></pre>
      </div>
      <p class="dev-ep-note" set:html={t.listNote}></p>
    </article>

    <article class="dev-ep">
      <header class="dev-ep-head">
        <span class="dev-verb">GET</span>
        <code class="dev-route">/v1/datacenters/&#123;id&#125;</code>
        <span class="dev-tag dev-tag-paid">{t.detailTag}</span>
      </header>
      <p class="dev-ep-name">{t.detailName}</p>
      <p class="dev-ep-desc" set:html={t.detailDesc}></p>
      <p class="dev-code-label">{t.reqLabel}</p>
      <div class="dev-codewrap dev-copyable">
        <pre class="dev-code"><code class="dev-copy-src">{detailSample}</code></pre>
        <button class="dev-copy-btn dev-copy-abs" type="button" data-copy={t.copy} data-copied={t.copied} aria-label={t.copy}>{t.copy}</button>
      </div>
      <p class="dev-ep-note" set:html={t.detailNote}></p>
    </article>
  </div>
</section>

<section class="section" id="compare">
  <div class="section-inner">
    <h2 class="dev-h2">{t.cmpTitle}</h2>
    <table class="dev-compare">
      <thead><tr>{t.cmpCols.map((c, i) => <th class={i === 0 ? "" : (i === 2 ? "dev-cmp-pro" : "dev-cmp-free")}>{c}</th>)}</tr></thead>
      <tbody>
        {t.cmpRows.map((row: any) => (
          <tr>
            <td>{row[0]}</td>
            <td class="dev-cmp-cell">{row[1] ? <span class="dev-yes">✓</span> : <span class="dev-no">—</span>}</td>
            <td class="dev-cmp-cell dev-cmp-pro">{row[2] ? <span class="dev-yes">✓</span> : <span class="dev-no">—</span>}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<section class="section section-tinted">
  <div class="section-inner dev-split">
    <div>
      <h2 class="dev-h2">{t.authTitle}</h2>
      <p class="dev-body" set:html={t.authBody}></p>
    </div>
    <div>
      <h2 class="dev-h2">{t.errTitle}</h2>
      <table class="dev-errors">
        <thead><tr>{t.errCols.map((c) => <th>{c}</th>)}</tr></thead>
        <tbody>
          {errors.map(([code, name, when]) => (
            <tr><td><span class="dev-err-code">{code}</span></td><td><code>{name}</code></td><td>{when}</td></tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="section" id="pricing">
  <div class="section-inner">
    <h2 class="dev-h2">{t.priceTitle}</h2>
    <div class="dev-tiers">
      {t.tiers.map((tier: any) => (
        <div class={`dev-tier${tier.cta?.primary ? " dev-tier-feat" : ""}`}>
          <p class="dev-tier-name">{tier.name}</p>
          <p class="dev-tier-price">{tier.price}</p>
          {tier.quota && <p class="dev-tier-quota">{tier.quota}</p>}
          <p class="dev-tier-copy">{tier.copy}</p>
          {tier.cta && (
            <a class={`button ${tier.cta.primary ? "button-primary" : "button-secondary"}`} href={tier.cta.href}>{tier.cta.label}</a>
          )}
        </div>
      ))}
    </div>
    <div class="dev-usecases">
      <span class="dev-uc-label">{t.useTitle}</span>
      {t.useCases.map((u: string) => <span class="dev-uc-chip">{u}</span>)}
    </div>
  </div>
</section>

<section class="section section-tinted">
  <div class="section-inner dev-key-cta">
    <div>
      <h2 class="dev-h2">{t.keyTitle}</h2>
      <p class="dev-body">{t.keyBody}</p>
    </div>
    <a class="button button-secondary" href={keyPath}>{t.keyLink}</a>
  </div>
</section>

<script>
  // Copy buttons (base URL + quick-start snippets). Each button sits in a
  // .dev-copyable and copies that block's .dev-copy-src text.
  for (const btn of document.querySelectorAll<HTMLButtonElement>(".dev-copy-btn")) {
    btn.addEventListener("click", async () => {
      const src = btn.closest(".dev-copyable")?.querySelector(".dev-copy-src");
      if (!src) return;
      try {
        await navigator.clipboard.writeText(src.textContent || "");
        const done = btn.dataset.copied || "✓";
        const label = btn.textContent;
        btn.textContent = done;
        setTimeout(() => { btn.textContent = label; }, 1500);
      } catch (e) { /* clipboard blocked — user can select manually */ }
    });
  }
</script>
