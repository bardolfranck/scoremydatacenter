// https://scoremydatacenter.org · independent data center acceptability-risk score
// "Qui sommes-nous" — one component, two homes: the landing #about section and
// the dedicated /fr/qui-sommes-nous page (texts in config/about.ts).
import iconMagnifier from "@phosphor-icons/core/assets/regular/magnifying-glass.svg?raw";
import iconStack from "@phosphor-icons/core/assets/regular/stack.svg?raw";
import iconShieldCheck from "@phosphor-icons/core/assets/regular/shield-check.svg?raw";
import iconCalculator from "@phosphor-icons/core/assets/regular/calculator.svg?raw";
import iconBell from "@phosphor-icons/core/assets/regular/bell.svg?raw";
import iconArticle from "@phosphor-icons/core/assets/regular/article.svg?raw";
import iconUserCircle from "@phosphor-icons/core/assets/regular/user-circle.svg?raw";
import iconGradCap from "@phosphor-icons/core/assets/regular/graduation-cap.svg?raw";
import iconUsersThree from "@phosphor-icons/core/assets/regular/users-three.svg?raw";
import iconChartUp from "@phosphor-icons/core/assets/regular/chart-line-up.svg?raw";
import iconBookOpen from "@phosphor-icons/core/assets/regular/book-open.svg?raw";
import iconBank from "@phosphor-icons/core/assets/regular/bank.svg?raw";
import iconCertificate from "@phosphor-icons/core/assets/regular/certificate.svg?raw";

interface Props {
  lang: "en" | "fr";
  t: Record<string, any>;
}
const { lang, t } = Astro.props;

// Production-chain icons (about section, review 2026-07-15: the credibility lives
// in the pipeline, not in a character gallery).
const CHAIN_ICONS: Record<string, string> = {
  collect: iconMagnifier, structure: iconStack, verify: iconShieldCheck,
  compute: iconCalculator, watch: iconBell, publish: iconArticle, human: iconUserCircle,
  gradcap: iconGradCap, users: iconUsersThree, chartup: iconChartUp,
  book: iconBookOpen, bank: iconBank, certificate: iconCertificate,
};
const chainIcon = (name: string, size = 22) =>
  (CHAIN_ICONS[name] ?? "").replace("<svg", `<svg width="${size}" height="${size}" fill="currentColor" aria-hidden="true"`);
---

  <section class="section section-tinted" id="about" aria-labelledby="about-title">
    <div class="section-inner">
      <div class="about-hero">
        <div class="about-left">
          <p class="hero-eyebrow" id="about-title">{t.aboutTitle}</p>
          <h2 class="about-h2" set:html={t.aboutHeadline}></h2>
          <p class="about-intro" set:html={t.founderLine}></p>
          <ul class="about-pledges">
            {t.aboutPledges.map((pl: any) => (
              <li><span class="ia-ic" aria-hidden="true" set:html={chainIcon(pl.icon)}></span><span set:html={pl.text}></span></li>
            ))}
          </ul>
        </div>
        <aside class="founder-card">
          <div class="founder-card-head">
            <img class="founder-card-photo" src="/assets/franck-bardol.jpg" alt={t.aboutPhotoAlt} width="110" height="127" loading="lazy" />
            <div>
              <h3>{t.founderHeading}</h3>
              <a class="founder-card-name" href={t.aboutLinkedinUrl} target="_blank" rel="noopener">Franck Bardol
                <svg width="15" height="15" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M216,24H40A16,16,0,0,0,24,40V216a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V40A16,16,0,0,0,216,24Zm0,192H40V40H216V216ZM96,112v64a8,8,0,0,1-16,0V112a8,8,0,0,1,16,0Zm88,28v36a8,8,0,0,1-16,0V140a20,20,0,0,0-40,0v36a8,8,0,0,1-16,0V112a8,8,0,0,1,15.79-1.78A36,36,0,0,1,184,140ZM100,84A12,12,0,1,1,88,72,12,12,0,0,1,100,84Z"/></svg></a>
            </div>
          </div>
          <ul class="founder-facts">
            {t.founderFacts.map((f: any) => (
              <li><span class="fact-ic" aria-hidden="true" set:html={chainIcon(f.icon, 18)}></span><span set:html={f.text}></span></li>
            ))}
          </ul>
        </aside>
      </div>
      {t.ia && (
        <div class="about-ia">
          <div class="section-heading">
            <h3 class="ia-heading">{t.ia.heading}</h3>
            <p set:html={t.ia.sub} />
          </div>
          <ol class="ia-chain">
            {t.ia.steps.map((step: any, i: number) => (
              <li class="ia-step">
                <span class="ia-num" aria-hidden="true">{i + 1}</span>
                <span class="ia-ic" aria-hidden="true" set:html={chainIcon(step.icon)}></span>
                <h4>{step.title}</h4>
                <p>{step.body}</p>
              </li>
            ))}
          </ol>
          <div class="ia-human">
            <span class="ia-ic ia-ic-human" aria-hidden="true" set:html={chainIcon("human", 26)}></span>
            <div>
              <strong>{t.ia.humanTitle}</strong>
              <p>{t.ia.humanBody}</p>
            </div>
          </div>
        </div>
      )}
      <div class="about-bottom">
        <div class="expertise">
          <p class="hero-eyebrow">{t.expertiseKicker}</p>
          <ul class="expertise-list">
            {t.expertise.map((e: any) => (
              <li>
                <span class="ia-ic" aria-hidden="true" set:html={chainIcon(e.icon)}></span>
                <div><strong>{e.title}</strong><span set:html={e.body}></span></div>
              </li>
            ))}
          </ul>
        </div>
        <aside class="strengths">
          <h3>{t.strengthsTitle}</h3>
          <ul>
            {t.strengths.map((st: string) => <li>{st}</li>)}
          </ul>
        </aside>
      </div>
      <div class="ia-closing">
        <p set:html={t.ia.closing}></p>
        <div class="ia-closing-actions">
          <a class="button button-primary" href={lang === "fr" ? "/fr/methodologie" : "/methodology"}>{t.ia.closingCta} →</a>
          <a class="ia-github" href={t.teamCtaUrl} target="_blank" rel="noopener">{t.teamCta}</a>
        </div>
      </div>
    </div>
  </section>
