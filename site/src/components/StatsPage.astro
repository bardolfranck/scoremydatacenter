---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Copyright (C) 2026 Franck Bardol and contributors — ScoreMyDataCenter
// https://scoremydatacenter.org · independent data center acceptability-risk score
// « Les chiffres du parc » — the perimeter template (T0, cadrage §4.10).
// One page per perimeter (Europe / country), FR default = France, EN default
// = Europe. Layout = validated v1 mock, re-skinned draft-4 (Bricolage display,
// Chivo text, mono data, navy #102A43). Every stat card: anchor, perimeter
// badge, n, per-country source line, copy-link. The engine gates what exists;
// this template only renders what stats.json publishes.
import "@fontsource/bricolage-grotesque/700.css";
import "@fontsource/bricolage-grotesque/800.css";
import Base from "../layouts/Base.astro";
import {
  STATS, T, SECTIONS, HERO_PRIORITY, REGION_NAMES,
  perimeterKeys, perimeterLabel, statView, fmtPct, fmtInt,
  type Lang,
} from "../config/stats";

interface Props {
  lang: Lang;
  perimeter: string; // "europe" | ISO country code
  nav: { href: string; label: string }[];
  basePath: string; // "/fr/chiffres" | "/figures"
  altBase: string;  // the twin page in the other language
}
const { lang, perimeter, nav, basePath, altBase } = Astro.props;
const t = T[lang];
const peri = STATS.perimeters[perimeter];
const defaultKey = lang === "fr" ? "FR" : "europe";
const pathFor = (key: string) =>
  key === defaultKey ? `${basePath}` : `${basePath}/${key.toLowerCase()}`;
const altPathFor = (key: string) => {
  const altDefault = lang === "fr" ? "europe" : "FR";
  return key === altDefault ? `${altBase}` : `${altBase}/${key.toLowerCase()}`;
};

const dateFmt = (iso: string | null) => {
  if (!iso) return "";
  const [y, m, d] = iso.split("-");
  const months = lang === "fr"
    ? ["janvier", "février", "mars", "avril", "mai", "juin", "juillet", "août", "septembre", "octobre", "novembre", "décembre"]
    : ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
  const mo = months[parseInt(m, 10) - 1];
  return lang === "fr" ? `${parseInt(d, 10)} ${mo} ${y}` : `${mo} ${parseInt(d, 10)}, ${y}`;
};

// LE chiffre — first priority stat this perimeter can publish.
const heroId = HERO_PRIORITY.find((id) => peri.stats[id]) ?? null;
const hero = heroId ? statView(peri, heroId, lang) : null;

// Perimeter badge for a card: names when few, count when many.
const totalCountries: number = peri.countries.length;
const badge = (countries: string[]) => {
  if (countries.length === 1 && countries[0] === "FR" && perimeter === "europe") return t.franceOnly;
  if (perimeter !== "europe") return perimeterLabel(perimeter, lang);
  return t.countriesOn(countries.length, totalCountries);
};

// Region payload (FR territoire selector) — the pre-computed per-region stats,
// embedded so the swap is instant and still 100% build-computed.
const regions = peri.regions ?? null;
const regionPayload = regions
  ? Object.fromEntries(Object.entries(regions).map(([slug, r]: [string, any]) => [slug, {
      label: REGION_NAMES[slug] ?? slug,
      n_sites: r.n_sites,
      stats: Object.fromEntries(SECTIONS[0].stats.map((id) => {
        const v = statView(r, id, lang);
        return [id, v ? { big: v.big, n: v.n } : { gated: r.gated?.[id] ?? 0 }];
      })),
    }]))
  : null;

const ogFor = (id: string) => `/og/stats/${lang}-${perimeter.toLowerCase()}-${id}.png`;
const pageOg = heroId ? new URL(ogFor(heroId), Astro.site ?? "https://scoremydatacenter.org").href : undefined;

const ANCHORS: Record<string, string> = {
  grid_saturated: "reseau-sature", grid_queue_critical: "file-attente",
  water_stress_high: "stress-hydrique", water_no_stress: "sans-stress",
  soil_artificialized: "sols-artificialises", protected_area_close: "zones-protegees",
  seveso_high_2km: "sites-a-risque", pue_published: "pue-publie",
  heat_reuse: "chaleur-valorisee", power_disclosed: "puissance-communiquee",
  operational_share: "parc-en-service", pipeline: "pipeline-mw", oppositions: "oppositions",
};

const sectionsToRender = SECTIONS.map((sec) => ({
  ...sec,
  cards: sec.stats
    .map((id) => ({ id, view: statView(peri, id, lang) }))
    .filter((c) => c.view),
})).filter((sec) => sec.cards.length > 0);
---

<Base
  lang={lang}
  title={`${t.h1} · ${perimeterLabel(perimeter, lang)} — ScoreMyDataCenter`}
  description={t.metaDescription}
  tagline={t.tagline}
  altHref={altPathFor(perimeter)}
  altLabel={lang === "fr" ? "🇬🇧 EN" : "🇫🇷 FR"}
  nav={nav}
  ogImage={pageOg}
>
  <div class="stx">
    <header class="stx-head">
      <h1 class="stx-h1">{t.h1}</h1>
      <p class="stx-lede">{t.lede}</p>
      <div class="stx-edition">
        {STATS.corpus_date && <span>{t.editionOf} <b>{dateFmt(STATS.corpus_date)}</b></span>}
        <span><b>{fmtInt(peri.n_sites, lang)}</b> {t.dcWord} · <b>{t.countriesWord(totalCountries)}</b></span>
        <span>{t.methodo} <b>v{STATS.methodology_version}</b></span>
        <label class="stx-peri">
          {t.perimeter}
          <select aria-label={t.perimeterSelectAria} data-peri-select>
            {["europe", ...perimeterKeys().filter((k) => k !== "europe")].map((key) => (
              <option value={pathFor(key)} selected={key === perimeter}>{perimeterLabel(key, lang)}</option>
            ))}
          </select>
        </label>
      </div>
    </header>

    {hero && (
      <div class="stx-hero" id={ANCHORS[heroId!]}>
        <div class="stx-hero-actions">
          <button class="stx-copy" type="button" data-copy={`${basePath === "/figures" ? "/figures" : basePath}${perimeter === defaultKey ? "" : "/" + perimeter.toLowerCase()}#${ANCHORS[heroId!]}`}>{t.copyLink}</button>
        </div>
        <p class="stx-kicker">{t.heroKicker}</p>
        <p class="stx-big"><em>{hero.big}</em></p>
        <p class="stx-fact">{hero.phrase}</p>
        <p class="stx-meta">
          {hero.src} · {t.nLabel} {fmtInt(hero.n, lang)} · <span class="stx-badge">{badge(hero.countries)}</span>
          {hero.excluded > 0 && <> · {t.excludedNote(hero.excluded)}</>}
        </p>
      </div>
    )}

    {sectionsToRender.map((sec) => (
      <section class="stx-section" aria-labelledby={`stx-${sec.id}`}>
        <div class="stx-sechead">
          <h2 id={`stx-${sec.id}`}>{(t.sections as any)[sec.id].title}</h2>
          <span class="stx-sub">{(t.sections as any)[sec.id].sub}</span>
          {sec.id === "territoire" && regionPayload && (
            <select class="stx-region" aria-label={t.regionAria} data-region-select>
              <option value="">{t.regionAll}</option>
              {Object.entries(regionPayload).map(([slug, r]: [string, any]) => (
                <option value={slug}>{r.label}</option>
              ))}
            </select>
          )}
        </div>
        <div class="stx-grid" data-section={sec.id}>
          {sec.cards.map(({ id, view }) => (
            <article class="stx-stat" id={ANCHORS[id]} data-stat={id}>
              <p class="stx-n" data-slot="big">{view!.big}</p>
              <p class="stx-f">{view!.phrase}</p>
              <p class="stx-src">
                <span>{view!.src} · {t.nLabel} <span data-slot="n">{fmtInt(view!.n, lang)}</span>
                  {view!.excluded > 0 && <> · {t.excludedNote(view!.excluded)}</>}</span>
                <span class="stx-srcend">
                  <span class="stx-badge" data-slot="badge">{badge(view!.countries)}</span>
                  <button class="stx-copy stx-copy-sm" type="button" data-copy={`${pathFor(perimeter)}#${ANCHORS[id]}`}>⧉</button>
                </span>
              </p>
              <p class="stx-gated" data-slot="gated" hidden></p>
            </article>
          ))}
        </div>
      </section>
    ))}

    <section class="stx-section" aria-labelledby="stx-methode">
      <div class="stx-sechead">
        <h2 id="stx-methode">{t.sections.methode.title}</h2>
        <span class="stx-sub">{t.sections.methode.sub}</span>
      </div>
      <div class="stx-grid">
        <article class="stx-stat" id="corpus">
          <p class="stx-n">{fmtInt(peri.n_sites, lang)}</p>
          <p class="stx-f">{t.method.corpus(peri.n_sites, totalCountries)}</p>
          <p class="stx-src"><span>{t.method.corpusSrc(STATS.methodology_version, STATS.corpus_date ? dateFmt(STATS.corpus_date) : "")}</span></p>
        </article>
        <article class="stx-stat" id="couverture">
          <p class="stx-n">{fmtPct(peri.coverage_mean_pct, lang)}</p>
          <p class="stx-f">{t.method.coverage}</p>
          <p class="stx-src"><span>{t.method.coverageSrc}</span></p>
        </article>
        <article class="stx-stat" id="ouvert">
          <p class="stx-n">{fmtPct(100, lang)}</p>
          <p class="stx-f">{t.method.open}</p>
          <p class="stx-src"><span><a href="https://github.com/bardolfranck/scoremydatacenter" target="_blank" rel="noopener">{t.method.openSrc} ↗</a></span></p>
        </article>
      </div>
    </section>
  </div>

  <script is:inline define:vars={{ regionPayload, copied: t.copied, regionGatedTpl: lang }}>
    // Perimeter navigation (static pages — the select is a link).
    document.querySelectorAll("[data-peri-select]").forEach(function (sel) {
      sel.addEventListener("change", function () { window.location.href = sel.value; });
    });
    // Copy-link buttons.
    document.querySelectorAll(".stx-copy").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var url = window.location.origin + btn.getAttribute("data-copy");
        navigator.clipboard && navigator.clipboard.writeText(url).then(function () {
          var old = btn.textContent; btn.textContent = copied;
          setTimeout(function () { btn.textContent = old; }, 1600);
        });
      });
    });
    // Region swap (FR territoire) — all values pre-computed at build.
    var regSel = document.querySelector("[data-region-select]");
    if (regSel && regionPayload) {
      var grid = document.querySelector('[data-section="territoire"]');
      var initial = {};
      grid.querySelectorAll("[data-stat]").forEach(function (card) {
        initial[card.getAttribute("data-stat")] = {
          big: card.querySelector('[data-slot="big"]').textContent,
          n: card.querySelector('[data-slot="n"]').textContent,
          badge: card.querySelector('[data-slot="badge"]').textContent,
        };
      });
      regSel.addEventListener("change", function () {
        var slug = regSel.value;
        grid.querySelectorAll("[data-stat]").forEach(function (card) {
          var id = card.getAttribute("data-stat");
          var big = card.querySelector('[data-slot="big"]');
          var n = card.querySelector('[data-slot="n"]');
          var bdg = card.querySelector('[data-slot="badge"]');
          var gated = card.querySelector('[data-slot="gated"]');
          var body = card.querySelector(".stx-f");
          var src = card.querySelector(".stx-src");
          if (!slug) {
            big.textContent = initial[id].big; n.textContent = initial[id].n;
            bdg.textContent = initial[id].badge;
            big.hidden = false; body.hidden = false; src.hidden = false; gated.hidden = true;
            return;
          }
          var r = regionPayload[slug];
          var v = r.stats[id];
          if (v && v.big !== undefined) {
            big.textContent = v.big; n.textContent = String(v.n); bdg.textContent = r.label;
            big.hidden = false; body.hidden = false; src.hidden = false; gated.hidden = true;
          } else {
            big.hidden = true; body.hidden = true; src.hidden = true;
            gated.textContent = (regionGatedTpl === "fr"
              ? "n insuffisant dans ce périmètre (n=" + (v ? v.gated : 0) + ") — pas de pourcentage sur si peu de sites"
              : "not enough sites in this perimeter (n=" + (v ? v.gated : 0) + ") — no percentage on so few sites");
            gated.hidden = false;
          }
        });
      });
    }
  </script>
</Base>
