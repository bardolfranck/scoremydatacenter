---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Copyright (C) 2026 Franck Bardol and contributors — ScoreMyDataCenter
// https://scoremydatacenter.org · independent data center acceptability-risk score
// The landing is fed by the engine's artifacts (scores.json, methodology.json)
// generated at build time — no hand-written grade ever appears here.
import Base from "../layouts/Base.astro";
import ScoreBadge from "./ScoreBadge.astro";
import AboutSection from "./AboutSection.astro";
import FeedbackBand from "./FeedbackBand.astro";
import MapIsland from "./MapIsland.astro";
import PillarIcon from "./PillarIcon.astro";
import type { PillarIconName } from "./PillarIcon.astro";
import scoresData from "../../public/data/scores.json";
import methodologyData from "../../public/data/methodology.json";

interface Props {
  lang: "en" | "fr";
  t: Record<string, any>;
}
const { lang, t } = Astro.props;

const scores = scoresData as any[];
const methodology = methodologyData as any;

// v2 hero (Franck GO 2026-07-15): the corpus at a glance — every figure computed
// from the build's own artifacts, never hand-written; no invented trends.
import { readFileSync } from "node:fs";
const real = scores.filter((d: any) => !d.id.startsWith("zz-"));
const dcFiles = import.meta.glob("../../public/data/dc/*.json", { eager: true });
const dcAll = Object.values(dcFiles).map((m: any) => (m as any).default).filter((d: any) => !d.id.startsWith("zz-"));
const stressCount = dcAll.filter((d: any) => (d.indicators || []).some((i: any) =>
  i.id === "W1" && ["high", "extremely_high"].includes(String(i.value ?? "").toLowerCase()))).length;
let watchCount = 0;
try { watchCount = JSON.parse(readFileSync(new URL("../../public/data/watchlist.geojson", import.meta.url), "utf8")).features.length; } catch { /* optional layer */ }
const nCountries = new Set(real.map((d: any) => d.country)).size;
const noPowerCount = real.filter((d: any) => typeof d.power_mw !== "number").length;
const corpusStats = [
  { figure: String(real.length), label: t.corpus.noted },
  { figure: String(nCountries), label: t.corpus.countries },
  { figure: String(stressCount), label: t.corpus.stress },
  { figure: String(watchCount), label: t.corpus.watch },
];
// Explore teasers — the strongest project and the two most exposed, percentile-framed
// (A-27 register: we situate, we never judge), plus the last scored fiches.
const graded = real.filter((d: any) => typeof d.grades.site.score === "number");
const sitePool = graded.map((d: any) => d.grades.site.score).sort((a: number, b: number) => a - b);
const bottomPct = (v: number) => Math.ceil((sitePool.filter((x: number) => x <= v).length / sitePool.length) * 100);
const byScore = [...graded].sort((a: any, b: any) => b.grades.site.score - a.grades.site.score);
const rankTeaser = [byScore[0], byScore[byScore.length - 1], byScore[byScore.length - 2]]
  .filter(Boolean).map((d: any) => ({ dc: d, p: Math.min(100, Math.max(1, bottomPct(d.grades.site.score))) }));
// "Latest scored" would need a real score_history — the bulk corpus has none yet,
// and we never invent a date. Until the audit history fills, the honest teaser is
// the highest DECLARED power (same MW story as the map).
const latest = [...real]
  .filter((d: any) => typeof d.power_mw === "number")
  .sort((a: any, b: any) => b.power_mw - a.power_mw)
  .slice(0, 5);
const ficheBase = lang === "fr" ? "/fr/dc" : "/dc";
const rankPath = lang === "fr" ? "/fr/classement" : "/ranking";
const pillarOrder = methodology.pillars.map((p: any) => p.id);

// The "money shot" (brief 2026-07-12 #3): a real published case whose fiche grades
// itself on scroll-in. Real data only — first non-fixture DC with a full pillar
// spread, so the animation reveals what is already published, never a mock.
const demo = scores.find((d: any) =>
  !d.id.startsWith("zz-") &&
  d.grades.site.grade !== "insufficient_data" &&
  d.grades.site.score != null &&
  pillarOrder.every((pid: string) => d.pillars[pid]?.grade && d.pillars[pid].grade !== "insufficient_data")
) ?? scores.find((d: any) => !d.id.startsWith("zz-") && d.grades.site.score != null);

const pillarIconName: Record<string, PillarIconName> = {
  energy: "energy", water: "water", land_biodiversity: "land",
  local_impact: "local", transparency_governance: "transparency",
};
// Distinct category colours for the weight donut (not the A–E grade palette).
const pillarColor: Record<string, string> = {
  energy: "#d98c1f", water: "#2a78d6", land_biodiversity: "#3b8a4f",
  local_impact: "#7a5bb0", transparency_governance: "#55677c",
};
// Weight donut as a conic-gradient — slices sum to exactly 100% (an honest
// part-of-whole, unlike a bar whose full track means nothing).
let _acc = 0;
const donutGradient = "conic-gradient(" + methodology.pillars.map((p: any) => {
  const start = Math.round(_acc * 100 * 10) / 10;
  _acc += p.weight;
  const end = Math.round(_acc * 100 * 10) / 10;
  return `${pillarColor[p.id]} ${start}% ${end}%`;
}).join(", ") + ")";
---

<Base
  lang={lang}
  title={t.title}
  description={t.description}
  tagline={t.tagline}
  altHref={t.altHref}
  altLabel={t.altLabel}
  nav={t.nav}
>
  <section class="hero hero-v2">
    <div class="hero-copy">
      {t.heroEyebrow && <p class="hero-eyebrow">{t.heroEyebrow}</p>}
      <h1 set:html={t.heroTitle}></h1>
      <p class="hero-lede">{t.heroLede}</p>
      <ul class="hero-checks">
        {t.heroChecks.map((c: string) => <li set:html={c}></li>)}
      </ul>
      <div class="hero-actions">
        <a class="button button-primary" href="#scores">{t.ctaScores}</a>
        <a class="button button-secondary" href="#method">{t.ctaMethod}</a>
      </div>
    </div>
    <aside class="hero-corpus" aria-label={t.corpus.aria}>
      <p class="corpus-label">{t.corpus.label}</p>
      <div class="corpus-stats">
        {corpusStats.map((stat) => (
          <div class="stat">
            <b><span class="sr-only">{stat.figure}</span><span class="stat-anim" aria-hidden="true">{stat.figure}</span></b>
            <span>{stat.label}</span>
          </div>
        ))}
      </div>
      <div class="corpus-scale">
        <div class="hero-scale" role="img" aria-label={t.heroScaleLabel}>
          <span class="hs-cell hs-a">A</span>
          <span class="hs-cell hs-b">B</span>
          <span class="hs-cell hs-c">C</span>
          <span class="hs-cell hs-d">D</span>
          <span class="hs-cell hs-e">E</span>
        </div>
        <p set:html={t.corpus.scaleNote}></p>
      </div>
    </aside>
  </section>

  <section class="manifesto" aria-label={t.manifesto.aria}>
    <div class="manifesto-inner">
      <div class="manifesto-shield" aria-hidden="true">✓</div>
      <div>
        <p class="manifesto-motto">{t.whyMotto}</p>
        <p class="manifesto-body">{t.manifesto.line1}</p>
        <p class="manifesto-body"><strong>{t.manifesto.contractLead}</strong> {t.manifesto.contract} <a href="#faq">{t.manifesto.link} →</a></p>
      </div>
    </div>
  </section>

  <section class="why-now" aria-label={t.whyNowAria}>
    <div class="why-now-inner">
      <div class="why-stats">
        {t.whyNowStats.map((stat: any) => (
          <div class="stat">
            {/* Final value lives in the HTML (no-JS / SEO / reduced-motion baseline);
                the count-up only replays it once on scroll-in. Sources never animate. */}
            <b><span class="sr-only">{stat.figure}</span><span class="stat-anim" aria-hidden="true">{stat.figure}</span>
              {/litres?|liters?/i.test(stat.figure) && <span class="stat-bar" aria-hidden="true"><i></i></span>}</b>
            {stat.url
              ? <a href={stat.url} target="_blank" rel="noopener">{stat.attribution}</a>
              : <span>{stat.attribution}</span>}
          </div>
        ))}
      </div>
      <p class="why-punch" set:html={t.whyNowPunch}></p>
    </div>
  </section>

  <section class="section section-tinted" id="mission" aria-labelledby="mission-title">
    <div class="section-inner">
      <p class="mission-line" id="mission-title">{t.missionLine}</p>
      <div class="mission-grid">
        <div class="why-block">
          <h3>{t.whyTitle}</h3>
          <p class="why-lede">{t.whyLede}</p>
          <p class="why-body" set:html={t.whyBody}></p>
        </div>
        {t.demo && demo && (
          <div class="score-demo">
            <p class="sr-only">{t.demo.sr.replace("{name}", demo.name)}</p>
            <div class="demo-anim" aria-hidden="true">
              <p class="demo-kicker">{t.demo.kicker}</p>
              <div class="demo-body">
                <div class="demo-pillars">
                  {pillarOrder.map((pid: string, i: number) => (
                    <div class="demo-cell demo-pop" style={`--pop-delay:${i * 260}ms`}>
                      <span class="demo-plabel">{t.pillarShort[pid]}</span>
                      <ScoreBadge
                        label={t.pillarShort[pid]}
                        grade={demo.pillars[pid]}
                        confidence={demo.confidence.level}
                        confidenceLabel={t.confidence[demo.confidence.level]}
                        renderConfidence={false}
                        renderLabel={false}
                        size="sm"
                        naLabel={t.insufficient}
                      />
                    </div>
                  ))}
                </div>
                <div class="demo-site">
                  <span class="demo-slabel">{t.siteScore}</span>
                  <span class="demo-score">{demo.grades.site.score.toFixed(1)}/100</span>
                  <span class="demo-bar"><i style={`--demo-score:${demo.grades.site.score / 100}`}></i></span>
                </div>
                <div class="demo-badge">
                  <ScoreBadge
                    label={t.siteScore}
                    grade={demo.grades.site}
                    confidence={demo.confidence.level}
                    confidenceLabel={t.confidence[demo.confidence.level]}
                    renderConfidence={false}
                    renderLabel={false}
                    size="lg"
                    naLabel={t.insufficient}
                  />
                </div>
              </div>
            </div>
            <p class="demo-caption">{t.demo.caption.replace("{name}", demo.name)}
              <button class="demo-replay" type="button">↻ {t.demo.replay}</button></p>
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="principles-section" aria-labelledby="principles-title">
    <h2 id="principles-title" class="principles-title">{t.principlesTitle}</h2>
    <div class="credibility-strip" aria-label={t.principlesAria}>
      {t.principles.map((p: any) => (
        <div>
          <strong>{p.title}</strong>
          <span>{p.body}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section" id="scores" aria-labelledby="scores-title">
    <div class="section-inner">
      <div class="section-heading">
        <h2 id="scores-title">{t.exploreTitle}</h2>
        <p>{t.exploreSub}</p>
      </div>
      <div class="explore-grid">
        <div class="explore-map">
          <p class="explore-label">{t.exploreMapLabel}</p>
          <MapIsland
            variant="hero"
            labels={{
              site: t.siteScore,
              operator: t.operatorScore,
              confidence: t.confidence,
              insufficient: t.insufficient,
              fixture: t.fixtureTag,
              openMap: t.mapOpen,
              reserved: t.mapReserved,
              ficheBase: ficheBase,
              mapPath: lang === "fr" ? "/fr/carte" : "/map",
              viewFiche: t.viewFiche,
              powerUnknown: lang === "fr" ? "puissance non communiquée" : "power not disclosed",
            }}
          />
        </div>
        <div class="explore-col">
          <p class="explore-label">{t.exploreRankLabel}</p>
          {rankTeaser.map(({ dc, p }) => (
            <a class="teaser-row" href={`${ficheBase}/${dc.id}`}>
              <ScoreBadge label={t.siteScore} grade={dc.grades.site} confidence={dc.confidence.level}
                confidenceLabel={t.confidence[dc.confidence.level]} renderConfidence={false} renderLabel={false}
                size="sm" naLabel={t.insufficient} />
              <span class="teaser-name">{dc.name}<small>{dc.country}{dc.power_mw ? ` — ${Math.round(dc.power_mw)} MW` : ""}{dc.grades.site.reserved_from ? ` — ${t.mapReserved.replace("· ", "")}` : ""}</small></span>
              <span class="teaser-pct">P{p}</span>
            </a>
          ))}
          <a class="teaser-more" href={rankPath}>{t.exploreRankMore} →</a>
        </div>
        <div class="explore-col">
          <p class="explore-label">{t.exploreLatestLabel}</p>
          {latest.map((dc: any) => (
            <a class="teaser-row" href={`${ficheBase}/${dc.id}`}>
              <ScoreBadge label={t.siteScore} grade={dc.grades.site} confidence={dc.confidence.level}
                confidenceLabel={t.confidence[dc.confidence.level]} renderConfidence={false} renderLabel={false}
                size="sm" naLabel={t.insufficient} />
              <span class="teaser-name">{dc.name}<small>{dc.country} — {Math.round(dc.power_mw)} MW</small></span>
            </a>
          ))}
          <a class="teaser-more" href={rankPath}>{t.exploreLatestMore} →</a>
        </div>
      </div>
      <form class="explore-search" action={rankPath} method="get" role="search">
        <input type="search" name="q" placeholder={t.searchPlaceholder} aria-label={t.searchPlaceholder} />
      </form>
    </div>
  </section>

  <section class="section section-tinted" id="matters" aria-labelledby="matters-title">
    <div class="section-inner">
      <div class="section-heading">
        <h2 id="matters-title">{t.mattersTitle}</h2>
        <p>{t.mattersSub}</p>
      </div>
      <div class="matters-grid">
        {t.matters.map((m: any) => (
          <div class="matters-card">
            <span class="matters-ic" aria-hidden="true"><PillarIcon name={m.icon} size={20} /></span>
            <h3>{m.title}</h3>
            <p set:html={m.body.replace("{stress}", String(stressCount)).replace("{total}", String(real.length)).replace("{noPower}", String(noPowerCount))}></p>
            <a href={m.href}>{m.link} →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-tinted" id="method" aria-labelledby="method-title">
    <div class="section-inner method-layout">
      <div class="method-copy">
        <h2 id="method-title">{t.methodTitle}</h2>
        <p class="prose" set:html={t.methodLede}></p>
        <ul class="dual-explain">
          <li>
            <strong>{t.siteScore}</strong>
            <span set:html={t.siteScoreExplain}></span>
          </li>
          <li>
            <strong>{t.operatorScore}</strong>
            <span set:html={t.operatorScoreExplain}></span>
          </li>
          <li>
            <strong>{t.confidenceTitle}</strong>
            <span>{t.confidenceExplain}</span>
          </li>
        </ul>
        {t.methodPedago && <a class="method-pedago" href={lang === "fr" ? "/fr/methodologie" : "/methodology"}>{t.methodPedago} →</a>}
      </div>
      <div class="weighting" aria-label={t.weightsAria}>
        <p class="weighting-caption">{t.weightsCaption}</p>
        <div class="donut-wrap">
          <div class="donut" style={`background: ${donutGradient}`} role="img" aria-label={t.weightsCaption}>
            <span class="donut-hole"></span>
          </div>
          <ul class="donut-legend">
            {methodology.pillars.map((p: any) => (
              <li>
                <span class="donut-ico" style={`color: ${pillarColor[p.id]}`}><PillarIcon name={pillarIconName[p.id]} size={16} /></span>
                <span class="donut-name">{p.label[lang]}</span>
                <b>{Math.round(p.weight * 100)}%</b>
              </li>
            ))}
          </ul>
        </div>
        <p class="weighting-caption" style="text-transform: none; letter-spacing: 0;">{t.weightsNote}</p>
      </div>
    </div>
  </section>

  <section class="section" id="library" aria-labelledby="library-title">
    <div class="section-inner home-lib">
      <div class="home-lib-cover" aria-hidden="true">
        <span class="home-lib-cover-brand">ScoreMyDataCenter</span>
        <b>{t.library.coverTitle}</b>
        <span class="home-lib-cover-bars"><i class="hs-a"></i><i class="hs-b"></i><i class="hs-c"></i><i class="hs-d"></i><i class="hs-e"></i></span>
      </div>
      <div class="home-lib-copy">
        <h2 id="library-title">{t.library.title}</h2>
        <p>{t.library.lede}</p>
        <ul>
          {t.library.items.map((it: string) => <li>{it}</li>)}
        </ul>
      </div>
      <a class="button button-primary home-lib-cta" href={lang === "fr" ? "/fr/bibliotheque" : "/intelligence"}>{t.library.cta} →</a>
    </div>
  </section>

  <section class="section section-dark" id="open" aria-labelledby="open-title">
    <div class="section-inner">
      <div class="section-heading">
        <h2 id="open-title">{t.openTitle}</h2>
        <p>{t.openLede}</p>
      </div>
      <div class="open-grid">
        {t.openCols.map((c: any) => (
          <article>
            <h3>{c.title}</h3>
            <p set:html={c.body}></p>
          </article>
        ))}
      </div>
      {t.openCta && (
        <a class="button button-secondary open-cta" href={t.repoUrl} target="_blank" rel="noopener">{t.openCta} ↗</a>
      )}
      <p class="redline" set:html={t.redline}></p>
    </div>
  </section>

  <section class="section" id="who" aria-labelledby="who-title">
    <div class="section-inner">
      <div class="section-heading">
        <h2 id="who-title">{t.whoTitle}</h2>
        <p>{t.whoSub}</p>
      </div>
      <div class="who-grid">
        {t.who.map((w: any) => (
          <a href={w.href}><b>{w.name}</b><span>{w.line}</span></a>
        ))}
      </div>
    </div>
  </section>

  <AboutSection lang={lang} t={t} />

  <section class="section" id="faq" aria-labelledby="faq-title">
    <div class="section-inner">
      <div class="section-heading">
        <h2 id="faq-title">{t.faqTitle}</h2>
      </div>
      <div class="faq-list">
        {t.faq.map((item: any) => (
          <details>
            <summary><span class="faq-q" set:html={item.q}></span></summary>
            <p set:html={item.a}></p>
          </details>
        ))}
      </div>
    </div>
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: t.faq.map((item: any) => ({
          "@type": "Question",
          name: item.q.replace(/<[^>]+>/g, ""),
          acceptedAnswer: { "@type": "Answer", text: item.a.replace(/<[^>]+>/g, "") },
        })),
      })}
    />
  </section>

  <FeedbackBand lang={lang} />

  <section class="contact-band" id="contact">
    <h2>{t.contactTitle}</h2>
    <a class="button button-primary" href="mailto:contact@scoremydatacenter.org">{t.contactCta}</a>
  </section>
</Base>

<script>
  // Count-up band (brief 2026-07-12 · motion is the data, not dressing): one pass on
  // scroll-in, 0→published value, ease-out cubes, ~160ms stagger. The HTML already
  // holds the final figures — this only replays them; reduced-motion never touches it.
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const countUpIn = (root: HTMLElement) => {
    const io = new IntersectionObserver((entries) => {
      if (!entries.some((e) => e.isIntersecting)) return;
      io.disconnect();
      root.querySelectorAll<HTMLElement>(".stat").forEach((stat, i) => {
        const el = stat.querySelector<HTMLElement>(".stat-anim");
        if (!el) return;
        const text = el.textContent || "";
        const m = text.match(/(\d+(?:[.,]\d+)?)/);
        if (!m || m.index === undefined) return;
        const finalToken = m[1];
        const decimals = /[.,]\d/.test(finalToken) ? 1 : 0;
        const sep = finalToken.includes(",") ? "," : ".";
        const target = parseFloat(finalToken.replace(",", "."));
        const before = text.slice(0, m.index);
        const after = text.slice(m.index + finalToken.length);
        el.style.minWidth = `${el.offsetWidth}px`; // reserve layout — zero CLS
        const bar = stat.querySelector<HTMLElement>(".stat-bar i");
        if (bar) bar.style.transform = "scaleX(0)";
        const start = performance.now() + i * 160;
        const DURATION = 1500;
        const frame = (now: number) => {
          const k = Math.min(Math.max((now - start) / DURATION, 0), 1);
          const eased = 1 - Math.pow(1 - k, 3);
          el.textContent = before + (target * eased).toFixed(decimals).replace(".", sep) + after;
          if (bar) bar.style.transform = `scaleX(${eased})`;
          if (k < 1) requestAnimationFrame(frame);
          else el.textContent = before + finalToken + after; // land exactly on the sourced value
        };
        requestAnimationFrame(frame);
      });
    }, { threshold: 0.4 });
    io.observe(root);
  };
  if (!reduced && "IntersectionObserver" in window) {
    document.querySelectorAll<HTMLElement>(".why-now, .hero-corpus").forEach(countUpIn);
  }

  // The self-grading fiche (brief #3): pillar chips pop, the SITE bar fills while
  // the score counts, the letter stamps in. All CSS-driven via .play; JS adds the
  // class and replays the (already final) score number. Plays once on scroll-in —
  // and the discreet "replay" button reruns it on demand (the browser restores the
  // scroll on reload, so the one automatic pass can fire before anyone watches).
  const demoEl = document.querySelector<HTMLElement>(".score-demo");
  if (demoEl && !reduced) {
    const scoreEl = demoEl.querySelector<HTMLElement>(".demo-score");
    const finalText = scoreEl?.textContent || "";
    const m = finalText.match(/(\d+(?:[.,]\d+)?)/);
    let run = 0; // replay cancels the previous count loop
    const playDemo = () => {
      demoEl.classList.remove("play");
      void demoEl.offsetWidth; // reflow so the CSS animations restart
      demoEl.classList.add("play");
      if (!scoreEl || !m) return;
      const mine = ++run;
      const target = parseFloat(m[1].replace(",", "."));
      const sep = m[1].includes(",") ? "," : ".";
      const start = performance.now() + 1600; // after the five pops
      const DUR = 1200;                        // in step with the bar fill
      const frame = (now: number) => {
        if (mine !== run) return;
        const k = Math.min(Math.max((now - start) / DUR, 0), 1);
        const eased = 1 - Math.pow(1 - k, 3);
        scoreEl.textContent = finalText.replace(m[1], (target * eased).toFixed(1).replace(".", sep));
        if (k < 1) requestAnimationFrame(frame);
        else scoreEl.textContent = finalText; // land exactly on the published score
      };
      requestAnimationFrame(frame);
    };
    demoEl.querySelector(".demo-replay")?.addEventListener("click", playDemo);
    if ("IntersectionObserver" in window) {
      const io2 = new IntersectionObserver((entries) => {
        if (!entries.some((e) => e.isIntersecting)) return;
        io2.disconnect();
        playDemo();
      }, { threshold: 0.4 });
      io2.observe(demoEl);
    }
  }
</script>
