---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Copyright (C) 2026 Franck Bardol and contributors — ScoreMyDataCenter
// https://scoremydatacenter.org · independent data center acceptability-risk score
// The landing is fed by the engine's artifacts (scores.json, methodology.json)
// generated at build time — no hand-written grade ever appears here.
import Base from "../layouts/Base.astro";
import ScoreBadge from "./ScoreBadge.astro";
import MapIsland from "./MapIsland.astro";
import PillarIcon from "./PillarIcon.astro";
import type { PillarIconName } from "./PillarIcon.astro";
import scoresData from "../../public/data/scores.json";
import methodologyData from "../../public/data/methodology.json";

interface Props {
  lang: "en" | "fr";
  t: Record<string, any>;
}
const { lang, t } = Astro.props;

const scores = scoresData as any[];
const methodology = methodologyData as any;
const pillarOrder = methodology.pillars.map((p: any) => p.id);

const pillarIconName: Record<string, PillarIconName> = {
  energy: "energy", water: "water", land_biodiversity: "land",
  local_impact: "local", transparency_governance: "transparency",
};
// Distinct category colours for the weight donut (not the A–E grade palette).
const pillarColor: Record<string, string> = {
  energy: "#d98c1f", water: "#2a78d6", land_biodiversity: "#3b8a4f",
  local_impact: "#7a5bb0", transparency_governance: "#55677c",
};
// Weight donut as a conic-gradient — slices sum to exactly 100% (an honest
// part-of-whole, unlike a bar whose full track means nothing).
let _acc = 0;
const donutGradient = "conic-gradient(" + methodology.pillars.map((p: any) => {
  const start = Math.round(_acc * 100 * 10) / 10;
  _acc += p.weight;
  const end = Math.round(_acc * 100 * 10) / 10;
  return `${pillarColor[p.id]} ${start}% ${end}%`;
}).join(", ") + ")";
---

<Base
  lang={lang}
  title={t.title}
  description={t.description}
  tagline={t.tagline}
  altHref={t.altHref}
  altLabel={t.altLabel}
  nav={t.nav}
>
  <section class="hero">
    <div class="hero-copy">
      <h1 set:html={t.heroTitle}></h1>
      <p class="hero-lede">{t.heroLede}</p>
      <div class="hero-scale" role="img" aria-label={t.heroScaleLabel}>
        <span class="hs-cell hs-a">A</span>
        <span class="hs-cell hs-b">B</span>
        <span class="hs-cell hs-c">C</span>
        <span class="hs-cell hs-d">D</span>
        <span class="hs-cell hs-e">E</span>
      </div>
      {t.heroKicker && <p class="hero-kicker">{t.heroKicker}</p>}
      <div class="hero-actions">
        <a class="button button-primary" href="#scores">{t.ctaScores}</a>
        <a class="button button-secondary" href="#method">{t.ctaMethod}</a>
      </div>
    </div>
    <MapIsland
      variant="hero"
      labels={{
        site: t.siteScore,
        operator: t.operatorScore,
        confidence: t.confidence,
        insufficient: t.insufficient,
        fixture: t.fixtureTag,
        openMap: t.mapOpen,
        reserved: t.mapReserved,
      }}
    />
  </section>

  <section class="why-now" aria-label={t.whyNowAria}>
    <div class="why-now-inner">
      <div class="why-stats">
        {t.whyNowStats.map((stat: any) => (
          <div class="stat">
            {/* Final value lives in the HTML (no-JS / SEO / reduced-motion baseline);
                the count-up only replays it once on scroll-in. Sources never animate. */}
            <b><span class="sr-only">{stat.figure}</span><span class="stat-anim" aria-hidden="true">{stat.figure}</span>
              {/litres?|liters?/i.test(stat.figure) && <span class="stat-bar" aria-hidden="true"><i></i></span>}</b>
            {stat.url
              ? <a href={stat.url} target="_blank" rel="noopener">{stat.attribution}</a>
              : <span>{stat.attribution}</span>}
          </div>
        ))}
      </div>
      <p class="why-punch" set:html={t.whyNowPunch}></p>
    </div>
  </section>

  <section class="section section-tinted" id="mission" aria-labelledby="mission-title">
    <div class="section-inner">
      <p class="mission-line" id="mission-title">{t.missionLine}</p>
      <div class="why-block">
        <h3>{t.whyTitle}</h3>
        <p class="why-lede">{t.whyLede}</p>
        <p class="why-body" set:html={t.whyBody}></p>
      </div>
    </div>
  </section>

  <section class="credibility-strip" aria-label={t.principlesAria}>
    {t.principles.map((p: any) => (
      <div>
        <strong>{p.title}</strong>
        <span>{p.body}</span>
      </div>
    ))}
  </section>

  <section class="section" id="scores" aria-labelledby="scores-title">
    <div class="section-inner">
      <div class="section-heading">
        <h2 id="scores-title">{t.scoresTitle}</h2>
        <p>{t.scoresLede}</p>
      </div>
      <div class="scorecard-grid">
        {scores.map((dc) => (
          <article class="scorecard">
            <div class="scorecard-head">
              <div>
                <p class="scorecard-status">{t.status[dc.project_status]} · {dc.power_mw} MW</p>
                <h3><a class="scorecard-name" href={`/fr/dc/${dc.id}`}>{dc.name}</a></h3>
                <p class="scorecard-place">{dc.municipality} ({dc.country}) — {dc.operator}</p>
              </div>
              <span class={`confidence ${dc.confidence.level}`}>
                <span class="dot" aria-hidden="true"></span>
                {t.confidence[dc.confidence.level]}
              </span>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px;">
              <ScoreBadge
                label={t.siteScore}
                grade={dc.grades.site}
                confidence={dc.confidence.level}
                confidenceLabel={t.confidence[dc.confidence.level]}
                renderConfidence={false}
                showScore={true}
                naLabel={t.insufficient}
              />
              <ScoreBadge
                label={t.operatorScore}
                grade={dc.grades.project_process}
                confidence={dc.confidence.level}
                confidenceLabel={t.confidence[dc.confidence.level]}
                renderConfidence={false}
                naLabel={t.insufficient}
              />
            </div>
            <dl class="pillar-row">
              {pillarOrder.map((pid: string) => (
                <div class="pillar-cell">
                  <dt>{t.pillarShort[pid]}</dt>
                  <dd>
                    <ScoreBadge
                      label={t.pillarShort[pid]}
                      grade={dc.pillars[pid]}
                      confidence={dc.confidence.level}
                      confidenceLabel={t.confidence[dc.confidence.level]}
                      renderConfidence={false}
                      renderLabel={false}
                      size="sm"
                      naLabel={t.insufficient}
                    />
                  </dd>
                </div>
              ))}
            </dl>
            {dc.id.startsWith("zz-") && <span class="fixture-tag">{t.fixtureTag}</span>}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-tinted" id="method" aria-labelledby="method-title">
    <div class="section-inner method-layout">
      <div class="method-copy">
        <h2 id="method-title">{t.methodTitle}</h2>
        <p class="prose" set:html={t.methodLede}></p>
        <ul class="dual-explain">
          <li>
            <strong>{t.siteScore}</strong>
            <span set:html={t.siteScoreExplain}></span>
          </li>
          <li>
            <strong>{t.operatorScore}</strong>
            <span set:html={t.operatorScoreExplain}></span>
          </li>
          <li>
            <strong>{t.confidenceTitle}</strong>
            <span>{t.confidenceExplain}</span>
          </li>
        </ul>
        {t.methodPedago && <a class="method-pedago" href={lang === "fr" ? "/fr/comprendre" : "/understand"}>{t.methodPedago} →</a>}
      </div>
      <div class="weighting" aria-label={t.weightsAria}>
        <p class="weighting-caption">{t.weightsCaption}</p>
        <div class="donut-wrap">
          <div class="donut" style={`background: ${donutGradient}`} role="img" aria-label={t.weightsCaption}>
            <span class="donut-hole"></span>
          </div>
          <ul class="donut-legend">
            {methodology.pillars.map((p: any) => (
              <li>
                <span class="donut-ico" style={`color: ${pillarColor[p.id]}`}><PillarIcon name={pillarIconName[p.id]} size={16} /></span>
                <span class="donut-name">{p.label[lang]}</span>
                <b>{Math.round(p.weight * 100)}%</b>
              </li>
            ))}
          </ul>
        </div>
        <p class="weighting-caption" style="text-transform: none; letter-spacing: 0;">{t.weightsNote}</p>
      </div>
    </div>
  </section>

  <section class="section section-dark" id="open" aria-labelledby="open-title">
    <div class="section-inner">
      <div class="section-heading">
        <h2 id="open-title">{t.openTitle}</h2>
        <p>{t.openLede}</p>
      </div>
      <div class="open-grid">
        {t.openCols.map((c: any) => (
          <article>
            <h3>{c.title}</h3>
            <p set:html={c.body}></p>
          </article>
        ))}
      </div>
      {t.openCta && (
        <a class="button button-secondary open-cta" href={t.repoUrl} target="_blank" rel="noopener">{t.openCta} ↗</a>
      )}
      <p class="redline" set:html={t.redline}></p>
    </div>
  </section>

  <section class="section section-tinted" id="about" aria-labelledby="about-title">
    <div class="section-inner">
      <div class="section-heading">
        <h2 id="about-title">{t.aboutTitle}</h2>
      </div>
      <div class="about-block">
        <span class="about-photo-lg" aria-hidden="true">FB</span>
        <div class="about-text">
          <p class="founder-line" set:html={t.founderLine}></p>
          <p class="about-todo">{t.aboutTodo}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="faq" aria-labelledby="faq-title">
    <div class="section-inner">
      <div class="section-heading">
        <h2 id="faq-title">{t.faqTitle}</h2>
      </div>
      <div class="faq-list">
        {t.faq.map((item: any) => (
          <details>
            <summary><span class="faq-q" set:html={item.q}></span></summary>
            <p set:html={item.a}></p>
          </details>
        ))}
      </div>
    </div>
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: t.faq.map((item: any) => ({
          "@type": "Question",
          name: item.q.replace(/<[^>]+>/g, ""),
          acceptedAnswer: { "@type": "Answer", text: item.a.replace(/<[^>]+>/g, "") },
        })),
      })}
    />
  </section>

  <section class="contact-band" id="contact">
    <h2>{t.contactTitle}</h2>
    <a class="button button-primary" href="mailto:contact@scoremydatacenter.org">{t.contactCta}</a>
  </section>
</Base>

<script>
  // Count-up band (brief 2026-07-12 · motion is the data, not dressing): one pass on
  // scroll-in, 0→published value, ease-out cubes, ~160ms stagger. The HTML already
  // holds the final figures — this only replays them; reduced-motion never touches it.
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const band = document.querySelector(".why-now");
  if (band && !reduced && "IntersectionObserver" in window) {
    const io = new IntersectionObserver((entries) => {
      if (!entries.some((e) => e.isIntersecting)) return;
      io.disconnect();
      document.querySelectorAll<HTMLElement>(".why-stats .stat").forEach((stat, i) => {
        const el = stat.querySelector<HTMLElement>(".stat-anim");
        if (!el) return;
        const text = el.textContent || "";
        const m = text.match(/(\d+(?:[.,]\d+)?)/);
        if (!m || m.index === undefined) return;
        const finalToken = m[1];
        const decimals = /[.,]\d/.test(finalToken) ? 1 : 0;
        const sep = finalToken.includes(",") ? "," : ".";
        const target = parseFloat(finalToken.replace(",", "."));
        const before = text.slice(0, m.index);
        const after = text.slice(m.index + finalToken.length);
        el.style.minWidth = `${el.offsetWidth}px`; // reserve layout — zero CLS
        const bar = stat.querySelector<HTMLElement>(".stat-bar i");
        if (bar) bar.style.transform = "scaleX(0)";
        const start = performance.now() + i * 160;
        const DURATION = 1500;
        const frame = (now: number) => {
          const k = Math.min(Math.max((now - start) / DURATION, 0), 1);
          const eased = 1 - Math.pow(1 - k, 3);
          el.textContent = before + (target * eased).toFixed(decimals).replace(".", sep) + after;
          if (bar) bar.style.transform = `scaleX(${eased})`;
          if (k < 1) requestAnimationFrame(frame);
          else el.textContent = before + finalToken + after; // land exactly on the sourced value
        };
        requestAnimationFrame(frame);
      });
    }, { threshold: 0.4 });
    io.observe(band);
  }
</script>
