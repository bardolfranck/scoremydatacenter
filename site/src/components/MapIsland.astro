---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Copyright (C) 2026 Franck Bardol and contributors — ScoreMyDataCenter
// https://scoremydatacenter.org · independent data center acceptability-risk score
// The living map — fed by map.geojson (engine artifact). Markers are grade
// chips; every popup shows both grades WITH the confidence level (the
// ScoreBadge invariant holds in client-rendered HTML too).
interface Props {
  variant: "hero" | "full";
  labels: {
    site: string;
    operator: string;
    confidence: Record<string, string>;
    insufficient: string;
    fixture: string;
    openMap?: string;
    // i18n (§13): link bases + strings the client script renders. FR defaults
    // apply when absent so existing callers keep working.
    ficheBase?: string;   // "/fr/dc" | "/dc"
    mapPath?: string;     // "/fr/carte" | "/map"
    viewFiche?: string;
    replyInProgress?: string;
    reserved?: string;
    legendGraded?: string;
    legendWatch?: string;
    watch?: { badge: string; note: string; source: string; press: string; selfReported: string; aria: string; title: string; status: Record<string, string> };
  };
}
const { variant, labels } = Astro.props;
---

<div class={`map-island map-${variant}`} data-variant={variant} data-labels={JSON.stringify(labels)}>
  <div class="map-canvas"></div>
  {variant === "hero" && labels.openMap && (
    <a class="button button-primary map-open-link" href={labels.mapPath ?? "/fr/carte"}>{labels.openMap}</a>
  )}
  {variant === "full" && (
    <div class="map-legend" aria-hidden="true">
      <span class="map-legend-grades">
        {["a", "b", "c", "d", "e"].map((g) => <i class={`legend-dot legend-${g}`}>{g.toUpperCase()}</i>)}
        {labels.legendGraded ?? "notes du site"}
      </span>
      <span><i class="legend-dot legend-dot-mw"></i>{labels.legendPower ?? "taille = puissance (MW) · petit point = non communiquée"}</span>
      <span class="legend-line-announced"><span class="map-legend-watch">🗣️</span>{labels.legendWatch ?? "En veille — suivi, pas encore noté"}</span>
      <span><span class="legend-emoji">✋🏼</span>{labels.legendWatchOpp ?? "Opposition citoyenne locale"}</span>
      <span><span class="legend-emoji">⏸️</span>{labels.legendWatchMor ?? "Moratoire (acte officiel 🏛️)"}</span>
    </div>
  )}
</div>

<script>
  import maplibregl from "maplibre-gl";
  import "maplibre-gl/dist/maplibre-gl.css";
  import { whitenBasemap } from "../scripts/basemap";

  const STYLE_URL = "https://tiles.openfreemap.org/styles/positron";

  function chip(grade: string, extra = ""): string {
    const na = grade === "insufficient_data";
    const cls = na ? "grade-na" : `grade-${grade.toLowerCase()}`;
    return `<span class="gradechip sm ${cls} ${extra}">${na ? "–" : grade}</span>`;
  }

  // Compact per-pillar scorecard for the popup (the fiche's score block in miniature).
  const PILLAR_SHORT: Record<string, string> = {
    energy: "Énergie", water: "Eau", land_biodiversity: "Foncier",
    local_impact: "Local", transparency_governance: "Transp.",
  };
  function pillarStrip(pillars: { id: string; grade: string }[]): string {
    if (!pillars?.length) return "";
    return `<div class="map-popup-pillars">${pillars
      .map((p) => `<span class="map-popup-pillar"><span>${PILLAR_SHORT[p.id] ?? p.id}</span>${chip(p.grade)}</span>`)
      .join("")}</div>`;
  }

  // Client-side mirror of the SourceLink component (A-20): live link + archived snapshot.
  function srcLink(s: any): string {
    if (!s?.url) return "—";
    const live = `<a href="${s.url}" target="_blank" rel="noopener">${s.title}${s.accessed ? ` — consulté le ${s.accessed}` : ""}</a>`;
    const archived = s.archived_url ? ` · <a href="${s.archived_url}" target="_blank" rel="noopener" class="src-archived">archivé</a>` : "";
    return live + archived;
  }

  document.querySelectorAll<HTMLElement>(".map-island").forEach(async (root) => {
    const labels = JSON.parse(root.dataset.labels || "{}");
    const isFull = root.dataset.variant === "full";
    const canvas = root.querySelector<HTMLElement>(".map-canvas");
    if (!canvas) return;

    const geo = await (await fetch("/data/map.geojson")).json();

    const map = new maplibregl.Map({
      container: canvas,
      style: STYLE_URL,
      center: [2.4, 46.8],
      zoom: isFull ? 5.3 : 4.7,
      attributionControl: { compact: true },
      scrollZoom: isFull,
      cooperativeGestures: isFull,
    });
    whitenBasemap(map);
    (root as any).__map = map; // test handle — verification scripts drive the view through it
    if (isFull) map.addControl(new maplibregl.NavigationControl({ showCompass: false }), "top-right");

    // Deep-link from the ranking: /fr/carte?dc=<id> flies to that project and opens its popup.
    const focusId = new URLSearchParams(location.search).get("dc");
    const markerById: Record<string, { marker: any; center: [number, number] }> = {};

    // Hero intro (brief 2026-07-12): motion is the data — the pins ARE the published
    // grades, they just drop in once. Browser-only; the artifacts never change.
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const animateIntro = !isFull && !reducedMotion;
    const DROP_WINDOW_MS = 2200; // whole cascade fits in ~2.2s whatever the pin count

    const bounds = new maplibregl.LngLatBounds();
    geo.features.forEach((feature: any, idx: number) => {
      const p = feature.properties;
      const [lon, lat] = feature.geometry.coordinates;
      bounds.extend([lon, lat]);

      const el = document.createElement("div");
      el.className = "map-marker";
      // Marker redesign (Franck 2026-07-13): a small dot in the site-grade colour,
      // no letter (the popup carries the letters). Known MW scales the diameter
      // (√MW — area reads as power), capped; unknown MW = a fixed SMALL solid dot
      // (dashed rings drowned 161/188 markers) — absence still shown as absence
      // by the fixed size, never an invented one. Known floor 14px keeps the two
      // distinguishable.
      const mw = typeof p.power_mw === "number" ? p.power_mw : null;
      const size = mw != null ? Math.round(Math.min(46, Math.max(14, 10 + 2 * Math.sqrt(mw)))) : 10;
      el.style.width = el.style.height = `${size}px`;
      const na = p.grade_site === "insufficient_data";
      const dot = document.createElement("span");
      dot.className = `map-dot ${na ? "dot-na" : `dot-${p.grade_site.toLowerCase()}`}${mw == null ? " mw-unknown" : ""}`;
      dot.title = `${p.name} — ${mw != null ? `${mw} MW` : (labels.powerUnknown ?? "puissance non communiquée")}`;
      el.appendChild(dot);
      if (animateIntro) {
        dot.classList.add("chip-drop");
        dot.style.setProperty("--pin-delay", `${Math.round((idx / geo.features.length) * DROP_WINDOW_MS)}ms`);
      }

      const fixtureTag = p.id.startsWith("zz-") ? `<span class="fixture-tag">${labels.fixture}</span>` : "";
      const popupHtml = `
        <div class="map-popup">
          <strong>${p.name}</strong>
          <span class="map-popup-sub">${p.power_mw != null ? `${p.power_mw} MW` : (labels.powerUnknown ?? "puissance non communiquée")}</span>
          <div class="map-popup-grades">
            <span>${labels.site} ${chip(p.grade_site)}${p.reserved_site ? `<span class="map-popup-reserved">${labels.reserved}</span>` : ""}</span>
            <span>${labels.operator} ${chip(p.grade_project_process)}${p.reserved_pp ? `<span class="map-popup-reserved">${labels.reserved}</span>` : ""}</span>
          </div>
          ${pillarStrip(p.pillars)}
          ${p.publication_status === "right_of_reply" ? `<p class="map-popup-reply">${labels.replyInProgress ?? "Droit de réponse en cours"}</p>` : ""}
          ${p.quote_fr ? `<p class="map-popup-quote">« ${p.quote_fr} »</p>` : ""}
          <span class="confidence ${p.confidence}"><span class="dot"></span>${labels.confidence[p.confidence]}</span>
          ${fixtureTag}
          <a class="map-popup-link" href="${labels.ficheBase ?? "/fr/dc"}/${p.id}">${labels.viewFiche || "Voir la fiche →"}</a>
        </div>`;

      const marker = new maplibregl.Marker({ element: el })
        .setLngLat([lon, lat])
        .setPopup(new maplibregl.Popup({ offset: 18, closeButton: false, maxWidth: "320px" }).setHTML(popupHtml))
        .addTo(map);
      markerById[p.id] = { marker, center: [lon, lat] };
    });

    // One light sweep after the pins have landed — a single pass, then gone.
    if (animateIntro) {
      const scan = document.createElement("div");
      scan.className = "map-scan";
      scan.setAttribute("aria-hidden", "true");
      scan.style.setProperty("--scan-delay", `${DROP_WINDOW_MS + 500}ms`);
      scan.addEventListener("animationend", () => scan.remove());
      canvas.appendChild(scan);
    }

    if (focusId && markerById[focusId]) {
      const { marker, center } = markerById[focusId];
      map.flyTo({ center, zoom: 9, duration: 800 });
      marker.togglePopup();
    } else if (geo.features.length > 1) {
      map.fitBounds(bounds, { padding: isFull ? 120 : 90, maxZoom: 7, duration: 0 });
    }

    // Watchlist layer (A-19) — world "En veille" projects: sourced facts, NEVER a
    // grade, a score or a confidence. Full map only. 863 entries (US wave 1) ride a
    // clustered geojson SOURCE (DOM markers would melt the map); only the rare
    // announced_project entries keep the DOM 🗣️ marker. Shape carries the kind —
    // round = local opposition, square = moratorium (official act) — same neutral
    // tint; the fine distinction lives in the popup, not in visual noise.
    if (isFull) {
      const W = Object.assign({
        badge: "En veille", note: "Projet suivi ; pas encore noté.",
        source: "Source :", press: "Presse : ", selfReported: "auto-déclaré",
        aria: "Projet suivi — contestation", title: "Projet suivi ; pas encore noté",
        lang: "fr",
        typeOpposition: "Opposition locale", typeMoratorium: "Moratoire",
        filterLabel: "En veille :", filterAll: "Tout", filterOppositions: "Oppositions",
        filterMoratoria: "Moratoires", filterAria: "Filtrer la couche en veille",
        viewWorld: "🇺🇸 US", viewEurope: "🇪🇺 Europe",
        status: { announced: "Annoncé", permitting: "En instruction",
                  under_construction: "En construction", operational: "En service" },
      }, labels.watch ?? {});
      const WATCH_STATUS: Record<string, string> = W.status;
      const GREY = "#c3d0dc", STROKE = "#ffffff", INK = "#33475c";
      try {
        const watch = await (await fetch("/data/watchlist.geojson")).json();
        const isClusteredKind = (f: any) => f.properties.kind === "opposition" || f.properties.kind === "moratorium";
        const clusteredAll = { type: "FeatureCollection", features: watch.features.filter(isClusteredKind) };
        const announced = watch.features.filter((f: any) => !isClusteredKind(f));

        // Shareable filter state, ranking-style URL: /fr/carte?veille=moratoires
        const FILTERS: Record<string, string | null> = { tout: null, oppositions: "opposition", moratoires: "moratorium" };
        let veille = new URLSearchParams(location.search).get("veille") ?? "tout";
        if (!(veille in FILTERS)) veille = "tout";
        const subset = (v: string) => FILTERS[v]
          ? { type: "FeatureCollection", features: clusteredAll.features.filter((f: any) => f.properties.kind === FILTERS[v]) }
          : clusteredAll;

        const watchBounds = new maplibregl.LngLatBounds();
        for (const f of watch.features) watchBounds.extend(f.geometry.coordinates);
        // View doctrine (COUNTRIES.md §6, decided 2026-07-13): the full map keeps the
        // EUROPE frame by default — the graded corpus is the product. The other shore
        // is one explicit click away, honestly labelled 🇺🇸 US (the watch layer is
        // US-only so far — "Monde" overpromised); an active ?veille= filter
        // auto-frames the layer it shows.
        const usBounds = new maplibregl.LngLatBounds();
        for (const f of watch.features) if (f.properties.country === "US") usBounds.extend(f.geometry.coordinates);
        const fitWorld = (ms = 600) => map.fitBounds(usBounds.isEmpty() ? watchBounds : usBounds, { padding: 60, maxZoom: 6, duration: ms });
        const fitEurope = (ms = 600) => map.fitBounds(bounds, { padding: 120, maxZoom: 7, duration: ms });

        const watchPopupHtml = (p: any) => {
          const facts = typeof p.facts === "string" ? JSON.parse(p.facts) : (p.facts || []);
          const src = typeof p.source === "string" && p.source.startsWith("{") ? JSON.parse(p.source) : p.source;
          const typeLabel = p.kind === "moratorium" ? W.typeMoratorium : p.kind === "opposition" ? W.typeOpposition : "";
          const sub = [[p.municipality, p.country].filter(Boolean).join(" · "),
            p.project_status ? WATCH_STATUS[p.project_status] : ""].filter(Boolean).join(" · ");
          const factItems = facts.map((f: any) =>
            `<li>${f.kind === "press" ? W.press : ""}${(f.label || {})[W.lang] ?? (f.label || {}).fr ?? ""}` +
            `${f.self_reported ? ` <span class="contestation-tag">${W.selfReported}</span>` : ""} — ${srcLink(f.source)}</li>`
          ).join("");
          return `
            <div class="map-popup watch-popup">
              <span class="watch-badge">${W.badge}</span>
              <strong>${typeLabel ? `${typeLabel} — ` : ""}${p.name}</strong>
              ${sub ? `<span class="map-popup-sub">${sub}</span>` : ""}
              <p class="watch-note">${W.note}</p>
              <p class="watch-src">${W.source} ${srcLink(src)}</p>
              ${factItems ? `<ul class="watch-facts">${factItems}</ul>` : ""}
            </div>`;
        };

        // announced_project (no hard fact yet): the existing DOM 🗣️ marker, unchanged.
        // Zero entries today (US wave 1) — hide its legend line rather than advertise
        // a marker that is nowhere on the map.
        if (!announced.length) root.querySelector(".legend-line-announced")?.remove();
        for (const feature of announced) {
          const el = document.createElement("div");
          el.className = "watch-marker";
          el.textContent = "🗣️";
          el.setAttribute("role", "img");
          el.setAttribute("aria-label", W.aria);
          el.title = W.title;
          new maplibregl.Marker({ element: el })
            .setLngLat(feature.geometry.coordinates)
            .setPopup(new maplibregl.Popup({ offset: 14, closeButton: false, maxWidth: "300px" }).setHTML(watchPopupHtml(feature.properties)))
            .addTo(map);
        }

        const onStyleReady = (fn: () => void) => (map.isStyleLoaded() ? fn() : map.once("load", fn));
        onStyleReady(() => {
          // Pictograms carry the kind (Franck 2026-07-14): ✋🏼 = local opposition (the
          // citizens' halt — deliberately NOT 🛑, red would read as a D/E grade),
          // ⏸️ = moratorium (the official pause). Maplibre glyphs have no emoji, so
          // rasterise via canvas (system emoji font) into layer icons.
          const emojiIcon = (name: string, emoji: string) => {
            const px = 48, cv = document.createElement("canvas");
            cv.width = cv.height = px;
            const ctx = cv.getContext("2d")!;
            ctx.font = "38px 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji', sans-serif";
            ctx.textAlign = "center"; ctx.textBaseline = "middle";
            ctx.fillText(emoji, px / 2, px / 2 + 2);
            map.addImage(name, ctx.getImageData(0, 0, px, px), { pixelRatio: 2 });
          };
          emojiIcon("watch-hand", "✋🏼");
          emojiIcon("watch-pause", "⏸️");

          map.addSource("watch", { type: "geojson", data: subset(veille), cluster: true, clusterMaxZoom: 10, clusterRadius: 44 });
          map.addLayer({ id: "watch-clusters", type: "circle", source: "watch", filter: ["has", "point_count"], paint: {
            "circle-color": GREY, "circle-opacity": 0.92,
            "circle-stroke-color": STROKE, "circle-stroke-width": 2,
            "circle-radius": ["step", ["get", "point_count"], 11, 10, 15, 50, 20, 200, 26],
          }});
          map.addLayer({ id: "watch-cluster-count", type: "symbol", source: "watch", filter: ["has", "point_count"], layout: {
            "text-field": ["get", "point_count_abbreviated"], "text-font": ["Noto Sans Bold"], "text-size": 11,
          }, paint: { "text-color": INK }});
          map.addLayer({ id: "watch-opposition", type: "symbol", source: "watch",
            filter: ["all", ["!", ["has", "point_count"]], ["==", ["get", "kind"], "opposition"]], layout: {
              "icon-image": "watch-hand", "icon-size": 0.8, "icon-allow-overlap": true,
            }});
          map.addLayer({ id: "watch-moratorium", type: "symbol", source: "watch",
            filter: ["all", ["!", ["has", "point_count"]], ["==", ["get", "kind"], "moratorium"]], layout: {
              "icon-image": "watch-pause", "icon-size": 0.8, "icon-allow-overlap": true,
            }});

          for (const layerId of ["watch-opposition", "watch-moratorium"]) {
            map.on("click", layerId, (e: any) => {
              new maplibregl.Popup({ offset: 12, closeButton: false, maxWidth: "300px" })
                .setLngLat(e.lngLat).setHTML(watchPopupHtml(e.features[0].properties)).addTo(map);
            });
            map.on("mouseenter", layerId, () => { map.getCanvas().style.cursor = "pointer"; });
            map.on("mouseleave", layerId, () => { map.getCanvas().style.cursor = ""; });
          }
          map.on("click", "watch-clusters", async (e: any) => {
            const cluster = e.features[0];
            const zoom = await (map.getSource("watch") as any).getClusterExpansionZoom(cluster.properties.cluster_id);
            map.easeTo({ center: cluster.geometry.coordinates, zoom, duration: 500 });
          });
          map.on("mouseenter", "watch-clusters", () => { map.getCanvas().style.cursor = "pointer"; });
          map.on("mouseleave", "watch-clusters", () => { map.getCanvas().style.cursor = ""; });

          // A ?veille= deep-link frames the layer it filters (dc focus wins).
          if (veille !== "tout" && !focusId) fitWorld(0);
        });

        // Filter control (shareable) + view toggle — mirrors the ranking's tweetable URLs.
        const ctl = document.createElement("div");
        ctl.className = "map-veille-ctl";
        ctl.setAttribute("role", "group");
        ctl.setAttribute("aria-label", W.filterAria);
        ctl.innerHTML =
          `<span class="veille-ctl-label">${W.filterLabel}</span>` +
          [["tout", W.filterAll], ["oppositions", W.filterOppositions], ["moratoires", W.filterMoratoria]]
            .map(([v, label]) => `<button type="button" data-veille="${v}"${v === veille ? ' class="active"' : ""}>${label}</button>`).join("") +
          `<span class="veille-ctl-sep"></span>` +
          `<button type="button" data-view="world">${W.viewWorld}</button>` +
          `<button type="button" data-view="europe">${W.viewEurope}</button>`;
        canvas.appendChild(ctl);
        ctl.addEventListener("click", (e) => {
          const btn = (e.target as HTMLElement).closest("button");
          if (!btn) return;
          if (btn.dataset.view === "world") return fitWorld();
          if (btn.dataset.view === "europe") return fitEurope();
          veille = btn.dataset.veille!;
          (map.getSource("watch") as any)?.setData(subset(veille));
          ctl.querySelectorAll("[data-veille]").forEach((b) => b.classList.toggle("active", (b as HTMLElement).dataset.veille === veille));
          const url = new URL(location.href);
          if (veille === "tout") url.searchParams.delete("veille"); else url.searchParams.set("veille", veille);
          history.replaceState(null, "", url);
          if (veille !== "tout") fitWorld();
        });
      } catch {
        /* no watchlist artifact yet — the layer is optional */
      }
    }
  });
</script>
