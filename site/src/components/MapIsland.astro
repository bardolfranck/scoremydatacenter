---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Copyright (C) 2026 Franck Bardol and contributors — ScoreMyDataCenter
// https://scoremydatacenter.org · independent data center acceptability-risk score
// The living map — fed by map.geojson (engine artifact). Markers are grade
// chips; every popup shows both grades WITH the confidence level (the
// ScoreBadge invariant holds in client-rendered HTML too).
interface Props {
  variant: "hero" | "full";
  labels: {
    site: string;
    operator: string;
    confidence: Record<string, string>;
    insufficient: string;
    fixture: string;
    openMap?: string;
    // i18n (§13): link bases + strings the client script renders. FR defaults
    // apply when absent so existing callers keep working.
    ficheBase?: string;   // "/fr/dc" | "/dc"
    mapPath?: string;     // "/fr/carte" | "/map"
    viewFiche?: string;
    replyInProgress?: string;
    reserved?: string;
    legendGraded?: string;
    legendWatch?: string;
    watch?: { badge: string; note: string; source: string; press: string; selfReported: string; aria: string; title: string; status: Record<string, string> };
  };
}
const { variant, labels } = Astro.props;
---

<div class={`map-island map-${variant}`} data-variant={variant} data-labels={JSON.stringify(labels)}>
  <div class="map-canvas"></div>
  {variant === "hero" && labels.openMap && (
    <a class="button button-primary map-open-link" href={labels.mapPath ?? "/fr/carte"}>{labels.openMap}</a>
  )}
  {variant === "full" && (
    <div class="map-legend" aria-hidden="true">
      <span class="map-legend-grades">
        {["a", "b", "c", "d", "e"].map((g) => <i class={`legend-dot legend-${g}`}>{g.toUpperCase()}</i>)}
        {labels.legendGraded ?? "note du site"}
      </span>
      <span><i class="legend-dot legend-dot-mw"></i>{labels.legendPower ?? "taille = puissance (MW) · petit point = non communiquée"}</span>
      <span><span class="map-legend-watch">🗣️</span>{labels.legendWatch ?? "En veille — suivi, pas encore noté"}</span>
    </div>
  )}
</div>

<script>
  import maplibregl from "maplibre-gl";
  import "maplibre-gl/dist/maplibre-gl.css";
  import { whitenBasemap } from "../scripts/basemap";

  const STYLE_URL = "https://tiles.openfreemap.org/styles/positron";

  function chip(grade: string, extra = ""): string {
    const na = grade === "insufficient_data";
    const cls = na ? "grade-na" : `grade-${grade.toLowerCase()}`;
    return `<span class="gradechip sm ${cls} ${extra}">${na ? "–" : grade}</span>`;
  }

  // Compact per-pillar scorecard for the popup (the fiche's score block in miniature).
  const PILLAR_SHORT: Record<string, string> = {
    energy: "Énergie", water: "Eau", land_biodiversity: "Foncier",
    local_impact: "Local", transparency_governance: "Transp.",
  };
  function pillarStrip(pillars: { id: string; grade: string }[]): string {
    if (!pillars?.length) return "";
    return `<div class="map-popup-pillars">${pillars
      .map((p) => `<span class="map-popup-pillar"><span>${PILLAR_SHORT[p.id] ?? p.id}</span>${chip(p.grade)}</span>`)
      .join("")}</div>`;
  }

  // Client-side mirror of the SourceLink component (A-20): live link + archived snapshot.
  function srcLink(s: any): string {
    if (!s?.url) return "—";
    const live = `<a href="${s.url}" target="_blank" rel="noopener">${s.title}${s.accessed ? ` — consulté le ${s.accessed}` : ""}</a>`;
    const archived = s.archived_url ? ` · <a href="${s.archived_url}" target="_blank" rel="noopener" class="src-archived">archivé</a>` : "";
    return live + archived;
  }

  document.querySelectorAll<HTMLElement>(".map-island").forEach(async (root) => {
    const labels = JSON.parse(root.dataset.labels || "{}");
    const isFull = root.dataset.variant === "full";
    const canvas = root.querySelector<HTMLElement>(".map-canvas");
    if (!canvas) return;

    const geo = await (await fetch("/data/map.geojson")).json();

    const map = new maplibregl.Map({
      container: canvas,
      style: STYLE_URL,
      center: [2.4, 46.8],
      zoom: isFull ? 5.3 : 4.7,
      attributionControl: { compact: true },
      scrollZoom: isFull,
      cooperativeGestures: isFull,
    });
    whitenBasemap(map);
    if (isFull) map.addControl(new maplibregl.NavigationControl({ showCompass: false }), "top-right");

    // Deep-link from the ranking: /fr/carte?dc=<id> flies to that project and opens its popup.
    const focusId = new URLSearchParams(location.search).get("dc");
    const markerById: Record<string, { marker: any; center: [number, number] }> = {};

    // Hero intro (brief 2026-07-12): motion is the data — the pins ARE the published
    // grades, they just drop in once. Browser-only; the artifacts never change.
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const animateIntro = !isFull && !reducedMotion;
    const DROP_WINDOW_MS = 2200; // whole cascade fits in ~2.2s whatever the pin count

    const bounds = new maplibregl.LngLatBounds();
    geo.features.forEach((feature: any, idx: number) => {
      const p = feature.properties;
      const [lon, lat] = feature.geometry.coordinates;
      bounds.extend([lon, lat]);

      const el = document.createElement("div");
      el.className = "map-marker";
      // Marker redesign (Franck 2026-07-13): a small dot in the site-grade colour,
      // no letter (the popup carries the letters). Known MW scales the diameter
      // (√MW — area reads as power), capped; unknown MW = a fixed SMALL solid dot
      // (dashed rings drowned 161/188 markers) — absence still shown as absence
      // by the fixed size, never an invented one. Known floor 14px keeps the two
      // distinguishable.
      const mw = typeof p.power_mw === "number" ? p.power_mw : null;
      const size = mw != null ? Math.round(Math.min(46, Math.max(14, 10 + 2 * Math.sqrt(mw)))) : 10;
      el.style.width = el.style.height = `${size}px`;
      const na = p.grade_site === "insufficient_data";
      const dot = document.createElement("span");
      dot.className = `map-dot ${na ? "dot-na" : `dot-${p.grade_site.toLowerCase()}`}${mw == null ? " mw-unknown" : ""}`;
      dot.title = `${p.name} — ${mw != null ? `${mw} MW` : (labels.powerUnknown ?? "puissance non communiquée")}`;
      el.appendChild(dot);
      if (animateIntro) {
        dot.classList.add("chip-drop");
        dot.style.setProperty("--pin-delay", `${Math.round((idx / geo.features.length) * DROP_WINDOW_MS)}ms`);
      }

      const fixtureTag = p.id.startsWith("zz-") ? `<span class="fixture-tag">${labels.fixture}</span>` : "";
      const popupHtml = `
        <div class="map-popup">
          <strong>${p.name}</strong>
          <span class="map-popup-sub">${p.power_mw != null ? `${p.power_mw} MW` : (labels.powerUnknown ?? "puissance non communiquée")}</span>
          <div class="map-popup-grades">
            <span>${labels.site} ${chip(p.grade_site)}${p.reserved_site ? `<span class="map-popup-reserved">${labels.reserved}</span>` : ""}</span>
            <span>${labels.operator} ${chip(p.grade_project_process)}${p.reserved_pp ? `<span class="map-popup-reserved">${labels.reserved}</span>` : ""}</span>
          </div>
          ${pillarStrip(p.pillars)}
          ${p.publication_status === "right_of_reply" ? `<p class="map-popup-reply">${labels.replyInProgress ?? "Droit de réponse en cours"}</p>` : ""}
          ${p.quote_fr ? `<p class="map-popup-quote">« ${p.quote_fr} »</p>` : ""}
          <span class="confidence ${p.confidence}"><span class="dot"></span>${labels.confidence[p.confidence]}</span>
          ${fixtureTag}
          <a class="map-popup-link" href="${labels.ficheBase ?? "/fr/dc"}/${p.id}">${labels.viewFiche || "Voir la fiche →"}</a>
        </div>`;

      const marker = new maplibregl.Marker({ element: el })
        .setLngLat([lon, lat])
        .setPopup(new maplibregl.Popup({ offset: 18, closeButton: false, maxWidth: "320px" }).setHTML(popupHtml))
        .addTo(map);
      markerById[p.id] = { marker, center: [lon, lat] };
    });

    // One light sweep after the pins have landed — a single pass, then gone.
    if (animateIntro) {
      const scan = document.createElement("div");
      scan.className = "map-scan";
      scan.setAttribute("aria-hidden", "true");
      scan.style.setProperty("--scan-delay", `${DROP_WINDOW_MS + 500}ms`);
      scan.addEventListener("animationend", () => scan.remove());
      canvas.appendChild(scan);
    }

    if (focusId && markerById[focusId]) {
      const { marker, center } = markerById[focusId];
      map.flyTo({ center, zoom: 9, duration: 800 });
      marker.togglePopup();
    } else if (geo.features.length > 1) {
      map.fitBounds(bounds, { padding: isFull ? 120 : 90, maxZoom: 7, duration: 0 });
    }

    // Watchlist layer (A-19) — world "En veille" projects: sourced facts, NEVER a
    // grade. Full map only (the graded DCs stay the hero focus). FR labels: this
    // layer is shown on /fr/carte. No letter is ever rendered here.
    if (isFull) {
      const W = labels.watch ?? {
        badge: "En veille", note: "Projet suivi ; pas encore noté.",
        source: "Source :", press: "Presse : ", selfReported: "auto-déclaré",
        aria: "Projet suivi — contestation", title: "Projet suivi ; pas encore noté",
        status: { announced: "Annoncé", permitting: "En instruction",
                  under_construction: "En construction", operational: "En service" },
      };
      const WATCH_STATUS: Record<string, string> = W.status;
      try {
        const watch = await (await fetch("/data/watchlist.geojson")).json();
        let watchExtended = false;
        for (const feature of watch.features) {
          const p = feature.properties;
          const [lon, lat] = feature.geometry.coordinates;
          bounds.extend([lon, lat]); // the "en veille" layer (incl. the US) belongs in frame
          watchExtended = true;
          const el = document.createElement("div");
          el.className = "watch-marker";
          el.textContent = "🗣️";
          el.setAttribute("role", "img");
          el.setAttribute("aria-label", W.aria);
          el.title = W.title;
          const sub = [[p.municipality, p.country].filter(Boolean).join(" · "),
            p.project_status ? WATCH_STATUS[p.project_status] : ""].filter(Boolean).join(" · ");
          const factItems = (p.facts || []).map((f: any) =>
            `<li>${f.kind === "press" ? W.press : ""}${f.label.fr}` +
            `${f.self_reported ? ` <span class="contestation-tag">${W.selfReported}</span>` : ""} — ${srcLink(f.source)}</li>`
          ).join("");
          const popupHtml = `
            <div class="map-popup watch-popup">
              <span class="watch-badge">${W.badge}</span>
              <strong>${p.name}</strong>
              ${sub ? `<span class="map-popup-sub">${sub}</span>` : ""}
              <p class="watch-note">${W.note}</p>
              <p class="watch-src">${W.source} ${srcLink(p.source)}</p>
              ${factItems ? `<ul class="watch-facts">${factItems}</ul>` : ""}
            </div>`;
          new maplibregl.Marker({ element: el })
            .setLngLat([lon, lat])
            .setPopup(new maplibregl.Popup({ offset: 14, closeButton: false, maxWidth: "300px" }).setHTML(popupHtml))
            .addTo(map);
        }
        // Re-frame to include the watchlist so the US pins aren't cropped out by the
        // Europe-only fit above. Skip when a deep-link already flew to one project.
        if (watchExtended && !focusId) {
          map.fitBounds(bounds, { padding: 120, maxZoom: 7, duration: 0 });
        }
      } catch {
        /* no watchlist artifact yet — the layer is optional */
      }
    }
  });
</script>
