    variant="full"
    labels={{
      site: "Site",
      operator: "Opérateur",
      confidence: { high: "confiance : haute", medium: "confiance : moyenne", low: "confiance : faible" },
      insufficient: "données insuffisantes",
      fixture: "Fixture de test fictive",
    }}
  />
</Base>
