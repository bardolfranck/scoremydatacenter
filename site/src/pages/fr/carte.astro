import Base from "../../layouts/Base.astro";
import MapIsland from "../../components/MapIsland.astro";

import { FR_NAV } from "../../config/nav";

const nav = FR_NAV;
---

<Base
  lang="fr"
  title="Carte des projets notés — ScoreMyDataCenter"
  description="La carte des projets de data centers notés A–E : deux notes par projet, sources et niveau de confiance."
  tagline="Observatoire indépendant"
  altHref="/map"
  altLabel="🇬🇧 EN"
  nav={nav}
>
  <MapIsland
    variant="full"
    labels={{
      site: "Site",
      operator: "Opérateur",
      confidence: { high: "confiance : haute", medium: "confiance : moyenne", low: "confiance : faible" },
      insufficient: "données insuffisantes",
      fixture: "Fixture de test fictive",
      reserved: "· A réservé",
      ficheBase: "/fr/dc",
      mapPath: "/fr/carte",
      viewFiche: "Voir la fiche →",
      replyInProgress: "Droit de réponse en cours",
    }}
  />
</Base>
