---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Copyright (C) 2026 Franck Bardol and contributors — ScoreMyDataCenter
// https://scoremydatacenter.org · independent data center acceptability-risk score
// Preview gallery: the social-share cards (OG images) as they render, so the
// design can be validated visually. The cards themselves are meta-tag images
// (invisible on the page) — this page is where you look at them.
import Base from "../../layouts/Base.astro";
import { FR_NAV } from "../../config/nav";

const modules = import.meta.glob("../../../public/data/dc/*.json", { eager: true });
const cards = Object.values(modules)
  .map((m: any) => m.default)
  .map((dc: any) => ({ id: dc.id, name: dc.name, png: `/og/dc/${dc.id}.png` }))
  .sort((a: any, b: any) => a.name.localeCompare(b.name, "fr"));
---

<Base
  lang="fr"
  title="Aperçu des cartes de partage — ScoreMyDataCenter"
  description="Les images sociales (Open Graph) générées pour chaque projet, telles qu'elles apparaissent sur X, WhatsApp et LinkedIn."
  tagline="Observatoire indépendant"
  altHref="/"
  altLabel="🇬🇧 EN"
  nav={FR_NAV}
>
  <section class="section">
    <div class="section-inner">
      <h1>Cartes de partage</h1>
      <p class="preview-intro">
        Voici l'image générée pour chaque projet (format 1200×630, design R4 / draft-4 3d).
        C'est ce qui s'affiche quand une fiche est partagée sur X, WhatsApp, LinkedIn ou par mail.
        Elle est intégrée en méta-donnée sur chaque fiche — invisible sur la page, visible au partage.
      </p>
      <div class="og-grid">
        {cards.map((c: any) => (
          <figure class="og-card">
            <a href={`/fr/dc/${c.id}`}>
              <img src={c.png} width="1200" height="630" loading="lazy" alt={`Carte de partage — ${c.name}`} />
            </a>
            <figcaption>{c.name}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .preview-intro { max-width: 62ch; color: #3d566e; margin: 0 0 2rem; }
  .og-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 460px), 1fr));
    gap: 1.75rem;
  }
  .og-card { margin: 0; }
  .og-card img {
    width: 100%;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 2px 10px rgba(16, 42, 67, 0.14);
    display: block;
  }
  .og-card figcaption {
    margin-top: 0.55rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: #102a43;
  }
</style>
