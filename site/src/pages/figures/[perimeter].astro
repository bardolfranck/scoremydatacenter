import StatsPage from "../../components/StatsPage.astro";
import { EN_NAV } from "../../config/nav";
import { perimeterKeys } from "../../config/stats";

export function getStaticPaths() {
  return perimeterKeys().filter((k) => k !== "europe")
    .map((k) => ({ params: { perimeter: k.toLowerCase() }, props: { key: k } }));
}
const { key } = Astro.props;
---

<StatsPage lang="en" perimeter={key} nav={EN_NAV} basePath="/figures" altBase="/fr/chiffres" />
