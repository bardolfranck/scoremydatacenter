const SITE = "https://scoremydatacenter.org";
// Facts only — every claim below is stated on this very page.
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${SITE}/#organization`,
      name: "ScoreMyDataCenter",
      url: SITE,
      logo: `${SITE}/assets/smdc-icon.svg`,
      description:
        "Independent observatory of data-center acceptability risk: two A–E grades per project, sources, confidence and an open method.",
      founder: { "@id": `${SITE}/#founder` },
      sameAs: ["https://github.com/bardolfranck/scoremydatacenter"],
    },
    {
      "@type": "Person",
      "@id": `${SITE}/#founder`,
      name: "Franck Bardol",
      jobTitle: "Founder",
      worksFor: { "@id": `${SITE}/#organization` },
      url: `${SITE}/who-we-are/`,
      image: `${SITE}/assets/franck-bardol.jpg`,
      sameAs: [
        "https://www.linkedin.com/in/franckbardol/",
        "https://www.meetup.com/paris-machine-learning-applications-group/",
      ],
    },
    {
      "@type": "AboutPage",
      "@id": `${SITE}/who-we-are/#page`,
      url: `${SITE}/who-we-are/`,
      name: "Who we are — ScoreMyDataCenter",
      inLanguage: "en",
      about: { "@id": `${SITE}/#organization` },
    },
  ],
};
---

<Base
  lang="en"
  title="Who we are — ScoreMyDataCenter"
  description="ScoreMyDataCenter is an independent observatory founded by Franck Bardol: the public acceptability score for data centers — open method, sources, human responsibility."
  tagline="Independent observatory"
  altHref="/fr/qui-sommes-nous"
  altLabel="🇫🇷 FR"
  nav={EN_NAV}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <AboutSection lang="en" t={EN_ABOUT} />
</Base>
